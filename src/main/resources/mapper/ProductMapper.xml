<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pet.mapper.ProductMapper">

    <resultMap id="BaseResultMap" type="com.pet.entity.Product">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="price" property="price"/>
        <result column="original_price" property="originalPrice"/>
        <result column="stock" property="stock"/>
        <result column="category_id" property="categoryId"/>
        <result column="category_name" property="categoryName"/>
        <result column="image" property="image"/>
        <result column="images" property="images"/>
        <result column="sales" property="sales"/>
        <result column="status" property="status"/>
        <result column="is_hot" property="isHot"/>
        <result column="is_new" property="isNew"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, description, price, original_price, stock, category_id, category_name,
        image, images, sales, status, is_hot, is_new, create_time, update_time
    </sql>

    <select id="getProductList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM product
        <where>
            status = 1
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%')
                OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="isHot != null">
                AND is_hot = #{isHot}
            </if>
            <if test="isNew != null">
                AND is_new = #{isNew}
            </if>
        </where>
        ORDER BY is_hot DESC, is_new DESC, sales DESC, id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countProduct" resultType="int">
        SELECT COUNT(*)
        FROM product
        <where>
            status = 1
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%')
                OR description LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
        </where>
    </select>

    <select id="getById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM product WHERE id = #{id}
    </select>

    <update id="updateStock">
        UPDATE product SET stock = stock + #{quantity}, sales = sales - #{quantity}
        WHERE id = #{id} AND stock + #{quantity} >= 0
    </update>

</mapper>