lor: #909399;\r\n  margin-left: 8px;\r\n}\r\n\r\n.dialog-footer {\r\n  text-align: right;\r\n  padding: 16px 24px 20px;\r\n  border-top: 1px solid #eef2f6;\r\n}\r\n</style>"]}]}