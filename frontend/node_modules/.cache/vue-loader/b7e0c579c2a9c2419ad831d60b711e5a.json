{"remainingRequest":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\admin\\AdminPetManage.vue?vue&type=style&index=0&id=febecf62&scoped=true&lang=css","dependencies":[{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\admin\\AdminPetManage.vue","mtime":1775537475762},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\css-loader\\dist\\cjs.js","mtime":1773246967392},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1773246970313},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\postcss-loader\\src\\index.js","mtime":1773246968437},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773246966744},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773246969499}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["AdminPetManage.vue"],"names":[],"mappings":";AAqvBA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"AdminPetManage.vue","sourceRoot":"src/views/admin","sourcesContent":["<template>\r\n  <div class=\"admin-pet-manage\">\r\n    <!-- 统计卡片 -->\r\n    <el-row :gutter=\"20\">\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-s-custom\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ statistics.totalPets || 0 }}</div>\r\n            <div class=\"stat-label\">总宠物数</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-plus\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ statistics.todayNew || 0 }}</div>\r\n            <div class=\"stat-label\">今日新增</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-dog\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ (statistics.typeCount && statistics.typeCount.dog) || 0 }}</div>\r\n            <div class=\"stat-label\">狗狗数量</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-cat\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ (statistics.typeCount && statistics.typeCount.cat) || 0 }}</div>\r\n            <div class=\"stat-label\">猫咪数量</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 操作栏 -->\r\n    <div class=\"action-bar\">\r\n      <div class=\"action-left\">\r\n        <el-button type=\"primary\" @click=\"handleAdd\" class=\"add-btn\">\r\n          <i class=\"el-icon-plus\"></i> 新增宠物\r\n        </el-button>\r\n        <el-button\r\n            v-if=\"selectedRows.length > 0\"\r\n            type=\"danger\"\r\n            plain\r\n            @click=\"handleBatchDelete\"\r\n            class=\"batch-btn\"\r\n        >\r\n          <i class=\"el-icon-delete\"></i> 批量删除 ({{ selectedRows.length }})\r\n        </el-button>\r\n      </div>\r\n      <div class=\"action-right\">\r\n        <div class=\"search-wrapper\">\r\n          <i class=\"el-icon-search search-icon\"></i>\r\n          <el-input\r\n              v-model=\"searchForm.keyword\"\r\n              placeholder=\"搜索宠物名/主人名\"\r\n              clearable\r\n              size=\"medium\"\r\n              @keyup.enter=\"handleSearch\"\r\n              class=\"search-input\"\r\n          >\r\n          </el-input>\r\n        </div>\r\n        <el-select\r\n            v-model=\"searchForm.type\"\r\n            placeholder=\"宠物类型\"\r\n            clearable\r\n            size=\"medium\"\r\n            class=\"status-select\"\r\n            @change=\"handleSearch\"\r\n        >\r\n          <el-option label=\"全部\" value=\"\"></el-option>\r\n          <el-option label=\"狗狗\" value=\"dog\"></el-option>\r\n          <el-option label=\"猫咪\" value=\"cat\"></el-option>\r\n          <el-option label=\"兔子\" value=\"rabbit\"></el-option>\r\n          <el-option label=\"鸟类\" value=\"bird\"></el-option>\r\n          <el-option label=\"鱼类\" value=\"fish\"></el-option>\r\n          <el-option label=\"其他\" value=\"other\"></el-option>\r\n        </el-select>\r\n        <el-button type=\"primary\" size=\"medium\" @click=\"handleSearch\" class=\"search-btn\">\r\n          搜索\r\n        </el-button>\r\n        <el-button size=\"medium\" @click=\"handleReset\" class=\"reset-btn\">\r\n          重置\r\n        </el-button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 宠物表格 -->\r\n    <el-table\r\n        v-loading=\"loading\"\r\n        :data=\"petList\"\r\n        stripe\r\n        style=\"width: 100%\"\r\n        class=\"pet-table\"\r\n        @selection-change=\"handleSelectionChange\"\r\n    >\r\n      <el-table-column type=\"selection\" width=\"45\" align=\"center\"></el-table-column>\r\n      <el-table-column prop=\"id\" label=\"ID\" width=\"70\" align=\"center\"></el-table-column>\r\n\r\n      <!-- 头像 -->\r\n      <el-table-column label=\"头像\" width=\"70\" align=\"center\">\r\n        <template slot-scope=\"scope\">\r\n          <el-avatar :size=\"40\" :src=\"scope.row.avatar\" class=\"pet-avatar\">\r\n            {{ scope.row.name ? scope.row.name.charAt(0).toUpperCase() : 'P' }}\r\n          </el-avatar>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 宠物信息 -->\r\n      <el-table-column label=\"宠物信息\" min-width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"pet-info-cell\">\r\n            <div class=\"pet-name\">{{ scope.row.name }}</div>\r\n            <div class=\"pet-type\">\r\n              <span class=\"type-tag\">{{ getTypeName(scope.row.type) }}</span>\r\n              <span v-if=\"scope.row.breed\" class=\"breed-text\">{{ scope.row.breed }}</span>\r\n            </div>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 主人信息 -->\r\n      <el-table-column label=\"主人\" width=\"150\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"owner-info\">\r\n            <span class=\"owner-name\">{{ scope.row.userName || '未知用户' }}</span>\r\n            <span class=\"owner-id\">ID: {{ scope.row.userId }}</span>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 基本信息 -->\r\n      <el-table-column label=\"基本信息\" width=\"180\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"basic-info-cell\">\r\n            <div><i class=\"el-icon-cake\"></i> {{ getAge(scope.row.birthday) }}</div>\r\n            <div><i class=\"el-icon-weight\"></i> {{ scope.row.weight || '--' }} kg</div>\r\n            <div><i class=\"el-icon-heart\"></i> {{ getGenderName(scope.row.gender) }}</div>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 毛色 -->\r\n      <el-table-column prop=\"color\" label=\"毛色\" width=\"100\">\r\n        <template slot-scope=\"scope\">\r\n          <span class=\"color-text\">{{ scope.row.color || '--' }}</span>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 是否默认 -->\r\n      <el-table-column label=\"默认\" width=\"80\" align=\"center\">\r\n        <template slot-scope=\"scope\">\r\n          <el-tag v-if=\"scope.row.isDefault === 1\" type=\"success\" size=\"small\">默认</el-tag>\r\n          <el-tag v-else type=\"info\" size=\"small\">否</el-tag>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 创建时间 -->\r\n      <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"160\">\r\n        <template slot-scope=\"scope\">\r\n          {{ formatDate(scope.row.createTime) }}\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 操作 -->\r\n      <el-table-column label=\"操作\" width=\"200\" fixed=\"right\" align=\"center\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"action-buttons\">\r\n            <el-button\r\n                size=\"small\"\r\n                type=\"primary\"\r\n                plain\r\n                @click=\"handleView(scope.row)\"\r\n                class=\"action-btn\"\r\n            >\r\n              <i class=\"el-icon-view\"></i> 详情\r\n            </el-button>\r\n            <el-button\r\n                size=\"small\"\r\n                type=\"warning\"\r\n                plain\r\n                @click=\"handleEdit(scope.row)\"\r\n                class=\"action-btn\"\r\n            >\r\n              <i class=\"el-icon-edit\"></i> 编辑\r\n            </el-button>\r\n            <el-button\r\n                size=\"small\"\r\n                type=\"danger\"\r\n                plain\r\n                @click=\"handleDelete(scope.row)\"\r\n                class=\"action-btn\"\r\n            >\r\n              <i class=\"el-icon-delete\"></i> 删除\r\n            </el-button>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 分页 -->\r\n    <div class=\"pagination-wrapper\">\r\n      <el-pagination\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handlePageChange\"\r\n          :current-page=\"page\"\r\n          :page-sizes=\"[10, 20, 50, 100]\"\r\n          :page-size=\"pageSize\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          :total=\"total\"\r\n          background\r\n      >\r\n      </el-pagination>\r\n    </div>\r\n\r\n    <!-- 新增/编辑宠物对话框 -->\r\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"showAddDialog\" width=\"580px\" center class=\"pet-dialog\">\r\n      <el-form :model=\"petForm\" :rules=\"petRules\" ref=\"petForm\" label-width=\"90px\">\r\n        <el-form-item label=\"宠物名称\" prop=\"name\">\r\n          <el-input v-model=\"petForm.name\" placeholder=\"请输入宠物名称\"></el-input>\r\n        </el-form-item>\r\n\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"宠物类型\" prop=\"type\">\r\n              <el-select v-model=\"petForm.type\" placeholder=\"请选择\" style=\"width: 100%\">\r\n                <el-option label=\"狗狗\" value=\"dog\"></el-option>\r\n                <el-option label=\"猫咪\" value=\"cat\"></el-option>\r\n                <el-option label=\"兔子\" value=\"rabbit\"></el-option>\r\n                <el-option label=\"鸟类\" value=\"bird\"></el-option>\r\n                <el-option label=\"鱼类\" value=\"fish\"></el-option>\r\n                <el-option label=\"其他\" value=\"other\"></el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"品种\">\r\n              <el-input v-model=\"petForm.breed\" placeholder=\"如：金毛\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"性别\">\r\n              <el-select v-model=\"petForm.gender\" placeholder=\"请选择\" style=\"width: 100%\">\r\n                <el-option label=\"公\" :value=\"1\"></el-option>\r\n                <el-option label=\"母\" :value=\"2\"></el-option>\r\n                <el-option label=\"未知\" :value=\"0\"></el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"生日\">\r\n              <el-date-picker v-model=\"petForm.birthday\" type=\"date\" placeholder=\"选择日期\" value-format=\"yyyy-MM-dd\" style=\"width: 100%\"></el-date-picker>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"体重(kg)\">\r\n              <el-input-number v-model=\"petForm.weight\" :min=\"0\" :max=\"100\" :precision=\"1\" controls-position=\"right\" style=\"width: 100%\"></el-input-number>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"毛色\">\r\n              <el-input v-model=\"petForm.color\" placeholder=\"如：金色\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-form-item label=\"简介\">\r\n          <el-input v-model=\"petForm.description\" type=\"textarea\" :rows=\"3\" placeholder=\"宠物简介\"></el-input>\r\n        </el-form-item>\r\n\r\n        <el-form-item label=\"是否默认\">\r\n          <el-switch v-model=\"petForm.isDefault\" :active-value=\"1\" :inactive-value=\"0\"></el-switch>\r\n        </el-form-item>\r\n      </el-form>\r\n\r\n      <span slot=\"footer\">\r\n        <el-button @click=\"showAddDialog = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitForm\" :loading=\"submitLoading\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n\r\n    <!-- 宠物详情对话框 -->\r\n    <el-dialog :title=\"currentPet && currentPet.name\" :visible.sync=\"showDetailDialog\" width=\"700px\" center>\r\n      <div class=\"pet-detail\" v-if=\"currentPet\">\r\n        <div class=\"detail-header\">\r\n          <el-avatar :size=\"80\" :src=\"currentPet.avatar\" class=\"detail-avatar\">\r\n            {{ currentPet.name ? currentPet.name.charAt(0).toUpperCase() : 'P' }}\r\n          </el-avatar>\r\n          <div class=\"detail-info\">\r\n            <h3>{{ currentPet.name }}</h3>\r\n            <div class=\"detail-meta\">\r\n              <span class=\"tag\">{{ getTypeName(currentPet.type) }}</span>\r\n              <span class=\"tag\" v-if=\"currentPet.breed\">{{ currentPet.breed }}</span>\r\n              <span class=\"tag\" v-if=\"currentPet.gender === 1\">♂ 公</span>\r\n              <span class=\"tag\" v-else-if=\"currentPet.gender === 2\">♀ 母</span>\r\n            </div>\r\n            <div class=\"detail-stats\">\r\n              <div><i class=\"el-icon-user\"></i> 主人：{{ currentPet.userName || '未知' }}</div>\r\n              <div><i class=\"el-icon-cake\"></i> {{ getAge(currentPet.birthday) }}</div>\r\n              <div><i class=\"el-icon-weight\"></i> {{ currentPet.weight || '--' }} kg</div>\r\n              <div><i class=\"el-icon-color\"></i> {{ currentPet.color || '--' }}</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"detail-tabs\">\r\n          <el-tabs v-model=\"activeTab\">\r\n            <el-tab-pane label=\"基本信息\" name=\"basic\">\r\n              <div class=\"basic-info\">\r\n                <div class=\"info-row\"><span>简介：</span><span>{{ currentPet.description || '暂无' }}</span></div>\r\n                <div class=\"info-row\"><span>生日：</span><span>{{ formatDate(currentPet.birthday) || '未知' }}</span></div>\r\n                <div class=\"info-row\"><span>注册时间：</span><span>{{ formatDate(currentPet.createTime) }}</span></div>\r\n              </div>\r\n            </el-tab-pane>\r\n\r\n            <el-tab-pane label=\"疫苗记录\" name=\"vaccine\">\r\n              <div class=\"vaccine-section\">\r\n                <el-button type=\"primary\" size=\"small\" @click=\"showVaccineDialog = true\">添加疫苗记录</el-button>\r\n                <el-table :data=\"currentPet.vaccineRecords || []\" style=\"margin-top: 15px\" size=\"small\">\r\n                  <el-table-column prop=\"vaccineName\" label=\"疫苗名称\"></el-table-column>\r\n                  <el-table-column prop=\"vaccineDate\" label=\"接种日期\" width=\"120\"></el-table-column>\r\n                  <el-table-column prop=\"nextDate\" label=\"下次接种\" width=\"120\"></el-table-column>\r\n                  <el-table-column prop=\"hospital\" label=\"医院\"></el-table-column>\r\n                  <el-table-column label=\"操作\" width=\"80\">\r\n                    <template slot-scope=\"scope\">\r\n                      <el-button type=\"text\" class=\"delete-btn\" @click=\"deleteVaccine(scope.row.id)\">删除</el-button>\r\n                    </template>\r\n                  </el-table-column>\r\n                </el-table>\r\n              </div>\r\n            </el-tab-pane>\r\n\r\n            <el-tab-pane label=\"体检记录\" name=\"health\">\r\n              <div class=\"health-section\">\r\n                <el-button type=\"primary\" size=\"small\" @click=\"showHealthDialog = true\">添加体检记录</el-button>\r\n                <el-table :data=\"currentPet.healthRecords || []\" style=\"margin-top: 15px\" size=\"small\">\r\n                  <el-table-column prop=\"recordDate\" label=\"体检日期\" width=\"120\"></el-table-column>\r\n                  <el-table-column prop=\"weight\" label=\"体重(kg)\" width=\"100\"></el-table-column>\r\n                  <el-table-column prop=\"healthStatus\" label=\"健康状况\"></el-table-column>\r\n                  <el-table-column label=\"操作\" width=\"80\">\r\n                    <template slot-scope=\"scope\">\r\n                      <el-button type=\"text\" class=\"delete-btn\" @click=\"deleteHealth(scope.row.id)\">删除</el-button>\r\n                    </template>\r\n                  </el-table-column>\r\n                </el-table>\r\n              </div>\r\n            </el-tab-pane>\r\n          </el-tabs>\r\n        </div>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 添加疫苗记录对话框 -->\r\n    <el-dialog title=\"添加疫苗记录\" :visible.sync=\"showVaccineDialog\" width=\"450px\" center>\r\n      <el-form :model=\"vaccineForm\" label-width=\"90px\">\r\n        <el-form-item label=\"疫苗名称\" required>\r\n          <el-input v-model=\"vaccineForm.vaccineName\" placeholder=\"如：狂犬疫苗\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"接种日期\" required>\r\n          <el-date-picker v-model=\"vaccineForm.vaccineDate\" type=\"date\" value-format=\"yyyy-MM-dd\" style=\"width: 100%\"></el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"下次接种\">\r\n          <el-date-picker v-model=\"vaccineForm.nextDate\" type=\"date\" value-format=\"yyyy-MM-dd\" style=\"width: 100%\"></el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"接种医院\">\r\n          <el-input v-model=\"vaccineForm.hospital\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"医生\">\r\n          <el-input v-model=\"vaccineForm.doctor\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"备注\">\r\n          <el-input v-model=\"vaccineForm.remark\" type=\"textarea\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <span slot=\"footer\">\r\n        <el-button @click=\"showVaccineDialog = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitVaccine\" :loading=\"vaccineLoading\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n\r\n    <!-- 添加体检记录对话框 -->\r\n    <el-dialog title=\"添加体检记录\" :visible.sync=\"showHealthDialog\" width=\"450px\" center>\r\n      <el-form :model=\"healthForm\" label-width=\"90px\">\r\n        <el-form-item label=\"体检日期\" required>\r\n          <el-date-picker v-model=\"healthForm.recordDate\" type=\"date\" value-format=\"yyyy-MM-dd\" style=\"width: 100%\"></el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"体重(kg)\">\r\n          <el-input-number v-model=\"healthForm.weight\" :min=\"0\" :precision=\"1\"></el-input-number>\r\n        </el-form-item>\r\n        <el-form-item label=\"健康状况\">\r\n          <el-input v-model=\"healthForm.healthStatus\" placeholder=\"如：良好\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"诊断结果\">\r\n          <el-input v-model=\"healthForm.diagnosis\" type=\"textarea\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"医生\">\r\n          <el-input v-model=\"healthForm.doctor\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <span slot=\"footer\">\r\n        <el-button @click=\"showHealthDialog = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitHealth\" :loading=\"healthLoading\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { getAdminPetList, addPet, updatePet, deletePet, batchDeletePets, getPetStatistics, addVaccineRecord, deleteVaccineRecord, addHealthRecord, deleteHealthRecord } from '@/api/pet';\r\nimport { getPetDetail } from '@/api/pet';\r\n\r\nexport default {\r\n  name: 'AdminPetManage',\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      submitLoading: false,\r\n      vaccineLoading: false,\r\n      healthLoading: false,\r\n      petList: [],\r\n      total: 0,\r\n      page: 1,\r\n      pageSize: 10,\r\n      selectedRows: [],\r\n      searchForm: {\r\n        keyword: '',\r\n        type: ''\r\n      },\r\n      statistics: {\r\n        totalPets: 0,\r\n        todayNew: 0,\r\n        typeCount: {}\r\n      },\r\n      showAddDialog: false,\r\n      showDetailDialog: false,\r\n      showVaccineDialog: false,\r\n      showHealthDialog: false,\r\n      isEdit: false,\r\n      editId: null,\r\n      currentPet: null,\r\n      activeTab: 'basic',\r\n      petForm: {\r\n        name: '',\r\n        type: 'dog',\r\n        breed: '',\r\n        gender: 0,\r\n        birthday: '',\r\n        weight: null,\r\n        color: '',\r\n        avatar: '',\r\n        description: '',\r\n        isDefault: 0\r\n      },\r\n      petRules: {\r\n        name: [{ required: true, message: '请输入宠物名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择宠物类型', trigger: 'change' }]\r\n      },\r\n      vaccineForm: {\r\n        petId: null,\r\n        vaccineName: '',\r\n        vaccineDate: '',\r\n        nextDate: '',\r\n        hospital: '',\r\n        doctor: '',\r\n        remark: ''\r\n      },\r\n      healthForm: {\r\n        petId: null,\r\n        recordDate: '',\r\n        weight: null,\r\n        healthStatus: '',\r\n        diagnosis: '',\r\n        doctor: ''\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    dialogTitle() {\r\n      return this.isEdit ? '编辑宠物' : '新增宠物';\r\n    }\r\n  },\r\n  created() {\r\n    this.loadList();\r\n    this.loadStatistics();\r\n  },\r\n  methods: {\r\n    async loadList() {\r\n      this.loading = true;\r\n      try {\r\n        const params = {\r\n          page: this.page,\r\n          pageSize: this.pageSize,\r\n          keyword: this.searchForm.keyword || undefined,\r\n          type: this.searchForm.type || undefined\r\n        };\r\n        const res = await getAdminPetList(params);\r\n        if (res.code === 200) {\r\n          this.petList = res.data.list || [];\r\n          this.total = res.data.total || 0;\r\n        }\r\n      } catch (error) {\r\n        console.error('加载失败', error);\r\n        this.$message.error('加载失败');\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    async loadStatistics() {\r\n      try {\r\n        const res = await getPetStatistics();\r\n        if (res.code === 200) {\r\n          this.statistics = res.data;\r\n        }\r\n      } catch (error) {\r\n        console.error('加载统计失败', error);\r\n      }\r\n    },\r\n    handleSearch() {\r\n      this.page = 1;\r\n      this.loadList();\r\n    },\r\n    handleReset() {\r\n      this.searchForm = { keyword: '', type: '' };\r\n      this.page = 1;\r\n      this.loadList();\r\n    },\r\n    handlePageChange(page) {\r\n      this.page = page;\r\n      this.loadList();\r\n    },\r\n    handleSizeChange(size) {\r\n      this.pageSize = size;\r\n      this.page = 1;\r\n      this.loadList();\r\n    },\r\n    handleSelectionChange(rows) {\r\n      this.selectedRows = rows;\r\n    },\r\n    getTypeName(type) {\r\n      const map = { dog: '狗狗', cat: '猫咪', rabbit: '兔子', bird: '鸟类', fish: '鱼类', other: '其他' };\r\n      return map[type] || '宠物';\r\n    },\r\n    getGenderName(gender) {\r\n      const map = { 0: '未知', 1: '公', 2: '母' };\r\n      return map[gender] || '未知';\r\n    },\r\n    getAge(birthday) {\r\n      if (!birthday) return '年龄未知';\r\n      const birth = new Date(birthday);\r\n      const now = new Date();\r\n      let age = now.getFullYear() - birth.getFullYear();\r\n      if (now.getMonth() < birth.getMonth() || (now.getMonth() === birth.getMonth() && now.getDate() < birth.getDate())) {\r\n        age--;\r\n      }\r\n      if (age <= 0) return '不到1岁';\r\n      return age + '岁';\r\n    },\r\n    formatDate(date) {\r\n      if (!date) return '';\r\n      const d = new Date(date);\r\n      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;\r\n    },\r\n    handleAdd() {\r\n      this.isEdit = false;\r\n      this.petForm = {\r\n        name: '',\r\n        type: 'dog',\r\n        breed: '',\r\n        gender: 0,\r\n        birthday: '',\r\n        weight: null,\r\n        color: '',\r\n        avatar: '',\r\n        description: '',\r\n        isDefault: 0\r\n      };\r\n      this.showAddDialog = true;\r\n    },\r\n    handleEdit(row) {\r\n      this.isEdit = true;\r\n      this.editId = row.id;\r\n      this.petForm = {\r\n        name: row.name,\r\n        type: row.type,\r\n        breed: row.breed || '',\r\n        gender: row.gender || 0,\r\n        birthday: row.birthday || '',\r\n        weight: row.weight,\r\n        color: row.color || '',\r\n        avatar: row.avatar || '',\r\n        description: row.description || '',\r\n        isDefault: row.isDefault || 0\r\n      };\r\n      this.showAddDialog = true;\r\n    },\r\n    async handleView(row) {\r\n      try {\r\n        const res = await getPetDetail(row.id);\r\n        if (res.code === 200) {\r\n          this.currentPet = res.data;\r\n          this.currentPet.vaccineRecords = this.currentPet.vaccineRecords || [];\r\n          this.currentPet.healthRecords = this.currentPet.healthRecords || [];\r\n          this.vaccineForm.petId = row.id;\r\n          this.healthForm.petId = row.id;\r\n          this.showDetailDialog = true;\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('获取详情失败');\r\n      }\r\n    },\r\n    async handleDelete(row) {\r\n      this.$confirm(`确定要删除宠物 \"${row.name}\" 吗？`, '提示', { type: 'warning' }).then(async () => {\r\n        try {\r\n          const res = await deletePet(row.id);\r\n          if (res.code === 200) {\r\n            this.$message.success('删除成功');\r\n            this.loadList();\r\n            this.loadStatistics();\r\n          }\r\n        } catch (error) {\r\n          this.$message.error('删除失败');\r\n        }\r\n      }).catch(() => {});\r\n    },\r\n    async handleBatchDelete() {\r\n      if (this.selectedRows.length === 0) return;\r\n      const ids = this.selectedRows.map(row => row.id).join(',');\r\n      this.$confirm(`确定要删除选中的 ${this.selectedRows.length} 个宠物吗？`, '提示', { type: 'warning' }).then(async () => {\r\n        try {\r\n          const res = await batchDeletePets(ids);\r\n          if (res.code === 200) {\r\n            this.$message.success(res.message);\r\n            this.selectedRows = [];\r\n            this.loadList();\r\n            this.loadStatistics();\r\n          }\r\n        } catch (error) {\r\n          this.$message.error('批量删除失败');\r\n        }\r\n      }).catch(() => {});\r\n    },\r\n    submitForm() {\r\n      this.$refs.petForm.validate(async (valid) => {\r\n        if (!valid) return;\r\n        this.submitLoading = true;\r\n        try {\r\n          let res;\r\n          if (this.isEdit) {\r\n            res = await updatePet({ ...this.petForm, id: this.editId });\r\n          } else {\r\n            res = await addPet(this.petForm);\r\n          }\r\n          if (res.code === 200) {\r\n            this.$message.success(res.message);\r\n            this.showAddDialog = false;\r\n            this.loadList();\r\n            this.loadStatistics();\r\n          } else {\r\n            this.$message.error(res.message);\r\n          }\r\n        } catch (error) {\r\n          this.$message.error(this.isEdit ? '更新失败' : '添加失败');\r\n        } finally {\r\n          this.submitLoading = false;\r\n        }\r\n      });\r\n    },\r\n    async submitVaccine() {\r\n      if (!this.vaccineForm.vaccineName || !this.vaccineForm.vaccineDate) {\r\n        this.$message.warning('请填写疫苗名称和接种日期');\r\n        return;\r\n      }\r\n      this.vaccineLoading = true;\r\n      try {\r\n        const res = await addVaccineRecord(this.vaccineForm);\r\n        if (res.code === 200) {\r\n          this.$message.success('添加成功');\r\n          this.showVaccineDialog = false;\r\n          this.vaccineForm = { petId: this.currentPet.id, vaccineName: '', vaccineDate: '', nextDate: '', hospital: '', doctor: '', remark: '' };\r\n          this.handleView({ id: this.currentPet.id });\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('添加失败');\r\n      } finally {\r\n        this.vaccineLoading = false;\r\n      }\r\n    },\r\n    async deleteVaccine(id) {\r\n      this.$confirm('确定删除该疫苗记录吗？', '提示', { type: 'warning' }).then(async () => {\r\n        try {\r\n          await deleteVaccineRecord(id);\r\n          this.$message.success('删除成功');\r\n          this.handleView({ id: this.currentPet.id });\r\n        } catch (error) {\r\n          this.$message.error('删除失败');\r\n        }\r\n      }).catch(() => {});\r\n    },\r\n    async submitHealth() {\r\n      if (!this.healthForm.recordDate) {\r\n        this.$message.warning('请填写体检日期');\r\n        return;\r\n      }\r\n      this.healthLoading = true;\r\n      try {\r\n        const res = await addHealthRecord(this.healthForm);\r\n        if (res.code === 200) {\r\n          this.$message.success('添加成功');\r\n          this.showHealthDialog = false;\r\n          this.healthForm = { petId: this.currentPet.id, recordDate: '', weight: null, healthStatus: '', diagnosis: '', doctor: '' };\r\n          this.handleView({ id: this.currentPet.id });\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('添加失败');\r\n      } finally {\r\n        this.healthLoading = false;\r\n      }\r\n    },\r\n    async deleteHealth(id) {\r\n      this.$confirm('确定删除该体检记录吗？', '提示', { type: 'warning' }).then(async () => {\r\n        try {\r\n          await deleteHealthRecord(id);\r\n          this.$message.success('删除成功');\r\n          this.handleView({ id: this.currentPet.id });\r\n        } catch (error) {\r\n          this.$message.error('删除失败');\r\n        }\r\n      }).catch(() => {});\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.admin-pet-manage {\r\n  padding: 20px;\r\n  background: #f5f7fa;\r\n  min-height: 100%;\r\n}\r\n\r\n/* 统计卡片 */\r\n.stat-card {\r\n  border-radius: 16px;\r\n  overflow: hidden;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.stat-card:hover {\r\n  transform: translateY(-4px);\r\n}\r\n\r\n.stat-card ::v-deep .el-card__body {\r\n  display: flex;\r\n  align-items: center;\r\n  padding: 20px;\r\n}\r\n\r\n.stat-icon {\r\n  width: 50px;\r\n  height: 50px;\r\n  border-radius: 12px;\r\n  background: linear-gradient(135deg, #667eea, #764ba2);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  margin-right: 15px;\r\n}\r\n\r\n.stat-icon i {\r\n  font-size: 24px;\r\n  color: white;\r\n}\r\n\r\n.stat-info {\r\n  flex: 1;\r\n}\r\n\r\n.stat-number {\r\n  font-size: 28px;\r\n  font-weight: bold;\r\n  color: #2c3e50;\r\n}\r\n\r\n.stat-label {\r\n  font-size: 14px;\r\n  color: #909399;\r\n  margin-top: 4px;\r\n}\r\n\r\n/* 操作栏 */\r\n.action-bar {\r\n  background: #fff;\r\n  border-radius: 16px;\r\n  padding: 16px 24px;\r\n  margin: 20px 0;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  flex-wrap: wrap;\r\n  gap: 16px;\r\n}\r\n\r\n.action-left {\r\n  display: flex;\r\n  gap: 12px;\r\n}\r\n\r\n.action-right {\r\n  display: flex;\r\n  gap: 12px;\r\n  align-items: center;\r\n}\r\n\r\n.search-wrapper {\r\n  position: relative;\r\n}\r\n\r\n.search-icon {\r\n  position: absolute;\r\n  left: 12px;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  color: #909399;\r\n}\r\n\r\n.search-input {\r\n  width: 200px;\r\n}\r\n\r\n.search-input ::v-deep .el-input__inner {\r\n  padding-left: 36px;\r\n  border-radius: 8px;\r\n}\r\n\r\n.s