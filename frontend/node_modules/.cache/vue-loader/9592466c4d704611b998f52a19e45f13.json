* 响应式 */\r\n@media (max-width: 768px) {\r\n  .settings-page {\r\n    padding: 12px;\r\n  }\r\n\r\n  .settings-content {\r\n    padding: 16px;\r\n  }\r\n\r\n  .tab-content {\r\n    max-width: 100%;\r\n  }\r\n\r\n  .upload-wrapper {\r\n    flex-direction: column;\r\n    align-items: flex-start;\r\n  }\r\n}\r\n</style>"]}]}