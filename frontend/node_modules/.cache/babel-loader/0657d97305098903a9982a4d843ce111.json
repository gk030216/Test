ost',\r\n        data\r\n    });\r\n}\r\n\r\n// ============= 管理员接口 =============\r\n\r\n// 获取订单列表（后台）\r\nexport function getAdminOrderList(params) {\r\n    return request({\r\n        url: '/admin/order/list',\r\n        method: 'get',\r\n        params\r\n    });\r\n}\r\n\r\n// 更新订单状态\r\nexport function updateOrderStatus(orderNo, orderStatus) {\r\n    return request({\r\n        url: '/admin/order/status',\r\n        method: 'put',\r\n        params: { orderNo, orderStatus }\r\n    });\r\n}\r\n\r\n// 删除订单\r\nexport function deleteOrder(id) {\r\n    return request({\r\n        url: `/admin/order/delete/${id}`,\r\n        method: 'delete'\r\n    });\r\n}\r\n\r\n// 批量删除订单\r\nexport function batchDeleteOrders(ids) {\r\n    return request({\r\n        url: '/admin/order/batch-delete',\r\n        method: 'delete',\r\n        params: { ids }\r\n    });\r\n}"],"mappings":"AAAA,OAAOA,OAAO,MAAM,iBAAiB;;AAErC;;AAEA;AACA,OAAO,SAASC,WAAWA,CAACC,IAAI,EAAE;EAC9B,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,eAAe;IACpBC,MAAM,EAAE,MAAM;IACdF;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASG,cAAcA,CAACC,OAAO,EAAE;EACpC,OAAON,OAAO,CAAC;IACXG,GAAG,EAAE,iBAAiBG,OAAO,EAAE;IAC/BF,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASG,YAAYA,CAACC,MAAM,EAAE;EACjC,OAAOR,OAAO,CAAC;IACXG,GAAG,EAAE,aAAa;IAClBC,MAAM,EAAE,KAAK;IACbI;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASC,WAAWA,CAACH,OAAO,EAAE;EACjC,OAAON,OAAO,CAAC;IACXG,GAAG,EAAE,iBAAiBG,OAAO,EAAE;IAC/BF,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASM,QAAQA,CAACR,IAAI,EAAE;EAC3B,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,YAAY;IACjBC,MAAM,EAAE,MAAM;IACdF;EACJ,CAAC,CAAC;AACN;;AAEA;;AAEA;AACA,OAAO,SAASS,iBAAiBA,CAACH,MAAM,EAAE;EACtC,OAAOR,OAAO,CAAC;IACXG,GAAG,EAAE,mBAAmB;IACxBC,MAAM,EAAE,KAAK;IACbI;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASI,iBAAiBA,CAACN,OAAO,EAAEO,WAAW,EAAE;EACpD,OAAOb,OAAO,CAAC;IACXG,GAAG,EAAE,qBAAqB;IAC1BC,MAAM,EAAE,KAAK;IACbI,MAAM,EAAE;MAAEF,OAAO;MAAEO;IAAY;EACnC,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASC,WAAWA,CAACC,EAAE,EAAE;EAC5B,OAAOf,OAAO,CAAC;IACXG,GAAG,EA