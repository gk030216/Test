{"remainingRequest":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\admin\\ProductCommentAnalysis.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\admin\\ProductCommentAnalysis.vue","mtime":1776450287203},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\babel.config.js","mtime":1773246789976},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773246966744},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1773246968572},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773246966744},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773246969499}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["echarts","getProductCommentStatistics","getProductCommentsList","replyComment","name","data","productId","productName","loading","commentLoading","stats","totalComments","avgRating","positiveRate","replyRate","ratingDistribution","commentTrend","commentList","page","pageSize","total","ratingFilter","replyContent","mounted","$route","query","loadStatistics","loadComments","$message","error","$router","back","methods","res","code","length","map","item","date","d","Date","getMonth","getDate","parts","split","parseInt","count","generateEmptyTrend","initCharts","console","params","rating","list","ratingChart","init","document","getElementById","ratingData","value","setOption","tooltip","trigger","formatter","legend","orient","left","series","type","radius","center","label","show","itemStyle","borderRadius","borderColor","borderWidth","color","trendChart","grid","right","bottom","containLabel","xAxis","yAxis","smooth","areaStyle","opacity","lineStyle","width","symbol","symbolSize","window","addEventListener","resize","handleRatingChange","handleReply","comment","content","id","trim","warning","success","message","handlePageChange","formatDate","getFullYear","String","padStart","getHours","getMinutes"],"sources":["src/views/admin/ProductCommentAnalysis.vue"],"sourcesContent":["<template>\r\n  <div class=\"product-comment-analysis\">\r\n    <!-- 返回按钮 -->\r\n    <div class=\"back-bar\">\r\n      <el-button icon=\"el-icon-arrow-left\" size=\"small\" @click=\"$router.back()\">返回</el-button>\r\n      <h2>{{ productName }} - 评价分析</h2>\r\n    </div>\r\n\r\n    <!-- 统计卡片 -->\r\n    <el-row :gutter=\"20\">\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-chat-dot-round\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ stats.totalComments }}</div>\r\n            <div class=\"stat-label\">总评价数</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-star-on\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ stats.avgRating }}</div>\r\n            <div class=\"stat-label\">平均评分</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-thumb\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ stats.positiveRate }}%</div>\r\n            <div class=\"stat-label\">好评率</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card class=\"stat-card\" shadow=\"hover\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"el-icon-message\"></i>\r\n          </div>\r\n          <div class=\"stat-info\">\r\n            <div class=\"stat-number\">{{ stats.replyRate }}%</div>\r\n            <div class=\"stat-label\">回复率</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 图表区域 -->\r\n    <el-row :gutter=\"20\" style=\"margin-top: 20px\">\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"chart-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"chart-header\">\r\n            <span>评分分布</span>\r\n          </div>\r\n          <div id=\"ratingChart\" style=\"height: 320px\"></div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"chart-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"chart-header\">\r\n            <span>评价趋势（近7天）</span>\r\n          </div>\r\n          <div id=\"trendChart\" style=\"height: 320px\"></div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 评价列表 -->\r\n    <el-row style=\"margin-top: 20px\">\r\n      <el-col :span=\"24\">\r\n        <el-card class=\"comment-list-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"chart-header\">\r\n            <span>用户评价</span>\r\n            <div class=\"filter-area\">\r\n              <el-select\r\n                  v-model=\"ratingFilter\"\r\n                  placeholder=\"筛选评分\"\r\n                  size=\"small\"\r\n                  clearable\r\n                  @change=\"handleRatingChange\"\r\n              >\r\n                <el-option label=\"全部\" :value=\"null\"></el-option>\r\n                <el-option label=\"5星\" :value=\"5\"></el-option>\r\n                <el-option label=\"4星\" :value=\"4\"></el-option>\r\n                <el-option label=\"3星\" :value=\"3\"></el-option>\r\n                <el-option label=\"2星\" :value=\"2\"></el-option>\r\n                <el-option label=\"1星\" :value=\"1\"></el-option>\r\n              </el-select>\r\n            </div>\r\n          </div>\r\n          <div class=\"comment-list\" v-loading=\"commentLoading\">\r\n            <div class=\"comment-item\" v-for=\"comment in commentList\" :key=\"comment.id\">\r\n              <el-avatar\r\n                  :size=\"40\"\r\n                  :src=\"comment.userAvatar\"\r\n                  class=\"comment-avatar\"\r\n              >\r\n                {{ comment.userName ? comment.userName.charAt(0) : 'U' }}\r\n              </el-avatar>\r\n              <div class=\"comment-content\">\r\n                <div class=\"comment-user\">\r\n                  <span class=\"user-name\">{{ comment.userName }}</span>\r\n                  <el-rate v-model=\"comment.rating\" disabled show-score text-color=\"#ff9900\"></el-rate>\r\n                  <span class=\"comment-time\">{{ formatDate(comment.createTime) }}</span>\r\n                </div>\r\n                <div class=\"comment-text\">{{ comment.content }}</div>\r\n                <div v-if=\"comment.images && comment.images.length\" class=\"comment-images\">\r\n                  <el-image\r\n                      v-for=\"(img, idx) in comment.images.split(',')\"\r\n                      :key=\"idx\"\r\n                      :src=\"img\"\r\n                      :preview-src-list=\"comment.images.split(',')\"\r\n                      fit=\"cover\"\r\n                      class=\"comment-img\"\r\n                  ></el-image>\r\n                </div>\r\n                <div v-if=\"comment.reply\" class=\"comment-reply\">\r\n                  <span class=\"reply-label\">商家回复：</span>\r\n                  <span>{{ comment.reply }}</span>\r\n                </div>\r\n                <div v-if=\"!comment.reply\" class=\"comment-reply-input\">\r\n                  <el-input\r\n                      v-model=\"replyContent[comment.id]\"\r\n                      placeholder=\"回复用户...\"\r\n                      size=\"small\"\r\n                      style=\"width: 300px\"\r\n                  ></el-input>\r\n                  <el-button size=\"small\" type=\"primary\" @click=\"handleReply(comment)\">回复</el-button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div v-if=\"commentList.length === 0\" class=\"empty-comment\">\r\n              <i class=\"el-icon-chat-dot-round\"></i>\r\n              <p>暂无评价数据</p>\r\n            </div>\r\n          </div>\r\n          <!-- 分页 -->\r\n          <div class=\"pagination-wrapper\" v-if=\"total > 0\">\r\n            <el-pagination\r\n                @current-change=\"handlePageChange\"\r\n                :current-page=\"page\"\r\n                :page-size=\"pageSize\"\r\n                layout=\"prev, pager, next\"\r\n                :total=\"total\"\r\n                small\r\n            ></el-pagination>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from 'echarts';\r\nimport { getProductCommentStatistics, getProductCommentsList, replyComment } from '@/api/comment';\r\n\r\nexport default {\r\n  name: 'ProductCommentAnalysis',\r\n  data() {\r\n    return {\r\n      productId: null,\r\n      productName: '',\r\n      loading: false,\r\n      commentLoading: false,\r\n      stats: {\r\n        totalComments: 0,\r\n        avgRating: 0,\r\n        positiveRate: 0,\r\n        replyRate: 0,\r\n        ratingDistribution: []\r\n      },\r\n      commentTrend: [],\r\n      commentList: [],\r\n      page: 1,\r\n      pageSize: 10,\r\n      total: 0,\r\n      ratingFilter: null,\r\n      replyContent: {}\r\n    };\r\n  },\r\n  mounted() {\r\n    // 获取路由参数\r\n    this.productId = this.$route.query.productId;\r\n    this.productName = this.$route.query.productName || '商品';\r\n\r\n    if (this.productId) {\r\n      this.loadStatistics();\r\n      this.loadComments();\r\n    } else {\r\n      this.$message.error('商品ID不存在');\r\n      this.$router.back();\r\n    }\r\n  },\r\n  methods: {\r\n    async loadStatistics() {\r\n      this.loading = true;\r\n      try {\r\n        const res = await getProductCommentStatistics(this.productId);\r\n        if (res.code === 200) {\r\n          this.stats = res.data;\r\n          // 处理 commentTrend 数据，确保日期格式正确\r\n          if (res.data.commentTrend && res.data.commentTrend.length > 0) {\r\n            this.commentTrend = res.data.commentTrend.map(item => {\r\n              // 处理时间戳或日期字符串\r\n              let date = item.date;\r\n              if (typeof date === 'number') {\r\n                // 如果是时间戳（毫秒）\r\n                const d = new Date(date);\r\n                date = `${d.getMonth() + 1}/${d.getDate()}`;\r\n              } else if (date) {\r\n                // 如果是字符串，只取月/日\r\n                const parts = date.split('-');\r\n                if (parts.length === 3) {\r\n                  date = `${parseInt(parts[1])}/${parseInt(parts[2])}`;\r\n                }\r\n              }\r\n              return {\r\n                date: date,\r\n                count: item.count\r\n              };\r\n            });\r\n          } else {\r\n            // 如果没有数据，生成近7天的空数据\r\n            this.commentTrend = this.generateEmptyTrend();\r\n          }\r\n          this.initCharts();\r\n        }\r\n      } catch (error) {\r\n        console.error('加载统计数据失败', error);\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n\r\n    async loadComments() {\r\n      this.commentLoading = true;\r\n      try {\r\n        const params = {\r\n          page: this.page,\r\n          pageSize: this.pageSize\r\n        };\r\n        // 修改这里：ratingFilter 有值时才添加\r\n        if (this.ratingFilter) {\r\n          params.rating = this.ratingFilter;\r\n        }\r\n        const res = await getProductCommentsList(this.productId, params);\r\n        if (res.code === 200) {\r\n          this.commentList = res.data.list;\r\n          this.total = res.data.total;\r\n        }\r\n      } catch (error) {\r\n        console.error('加载评价列表失败', error);\r\n      } finally {\r\n        this.commentLoading = false;\r\n      }\r\n    },\r\n\r\n    initCharts() {\r\n      // 评分分布饼图\r\n      const ratingChart = echarts.init(document.getElementById('ratingChart'));\r\n      const ratingData = (this.stats.ratingDistribution || []).map(item => ({\r\n        name: item.rating + '星',\r\n        value: item.count\r\n      }));\r\n\r\n      ratingChart.setOption({\r\n        tooltip: { trigger: 'item', formatter: '{b}: {d}% ({c}条)' },\r\n        legend: { orient: 'vertical', left: 'left' },\r\n        series: [{\r\n          type: 'pie',\r\n          radius: '55%',\r\n          center: ['50%', '50%'],\r\n          data: ratingData,\r\n          label: { show: true, formatter: '{b}: {d}%' },\r\n          itemStyle: {\r\n            borderRadius: 8,\r\n            borderColor: '#fff',\r\n            borderWidth: 2\r\n          }\r\n        }],\r\n        color: ['#f56c6c', '#e6a23c', '#f0b45c', '#67c23a', '#409EFF']\r\n      });\r\n\r\n      // 趋势折线图\r\n      const trendChart = echarts.init(document.getElementById('trendChart'));\r\n      trendChart.setOption({\r\n        tooltip: { trigger: 'axis' },\r\n        grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\r\n        xAxis: { type: 'category', data: this.commentTrend.map(item => item.date) },\r\n        yAxis: { type: 'value', name: '评价数量' },\r\n        series: [{\r\n          data: this.commentTrend.map(item => item.count),\r\n          type: 'line',\r\n          smooth: true,\r\n          areaStyle: { opacity: 0.3, color: '#409EFF' },\r\n          lineStyle: { color: '#409EFF', width: 2 },\r\n          symbol: 'circle',\r\n          symbolSize: 8\r\n        }]\r\n      });\r\n\r\n      window.addEventListener('resize', () => {\r\n        ratingChart.resize();\r\n        trendChart.resize();\r\n      });\r\n    },\r\n\r\n    handleRatingChange() {\r\n      this.page = 1;\r\n      this.loadComments();\r\n    },\r\n\r\n\r\n    async handleReply(comment) {\r\n      const content = this.replyContent[comment.id];\r\n      if (!content || !content.trim()) {\r\n        this.$message.warning('请输入回复内容');\r\n        return;\r\n      }\r\n\r\n      try {\r\n        const res = await replyComment(comment.id, content);\r\n        if (res.code === 200) {\r\n          this.$message.success('回复成功');\r\n          this.replyContent[comment.id] = '';\r\n          this.loadComments();\r\n          this.loadStatistics();\r\n        } else {\r\n          this.$message.error(res.message);\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('回复失败');\r\n      }\r\n    },\r\n\r\n    handlePageChange(page) {\r\n      this.page = page;\r\n      this.loadComments();\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return '';\r\n      const d = new Date(date);\r\n      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.product-comment-analysis {\r\n  padding: 20px;\r\n  background: #f5f7fa;\r\n  min-height: 100%;\r\n}\r\n\r\n.back-bar {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n  margin-bottom: 20px;\r\n  background: #fff;\r\n  padding: 12px 20px;\r\n  border-radius: 12px;\r\n}\r\n\r\n.back-bar h2 {\r\n  margin: 0;\r\n  font-size: 18px;\r\n  color: #2c3e50;\r\n}\r\n\r\n.stat-card {\r\n  border-radius: 16px;\r\n  overflow: hidden;\r\n  transition: all 0.3s;\