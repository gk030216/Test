{"remainingRequest":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\personal\\MyPets.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\personal\\MyPets.vue","mtime":1775497191930},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\babel.config.js","mtime":1773246789976},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773246966744},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1773246968572},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773246966744},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773246969499}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["getPetList","addPet","updatePet","deletePet","setDefaultPet","getUpcomingVaccines","addVaccineRecord","deleteVaccineRecord","addHealthRecord","deleteHealthRecord","uploadPetAvatar","name","data","loading","submitLoading","vaccineLoading","healthLoading","petList","upcomingVaccines","showAddDialog","showDetailDialog","showVaccineDialog","showHealthDialog","isEdit","editId","avatarPreview","currentPet","activeTab","petForm","type","breed","gender","birthday","weight","color","avatar","description","petRules","required","message","trigger","vaccineForm","petId","vaccineName","vaccineDate","nextDate","hospital","doctor","remark","healthForm","recordDate","height","temperature","healthStatus","diagnosis","computed","dialogTitle","created","loadPets","loadUpcomingVaccines","methods","res","code","error","$message","console","getTypeName","map","dog","cat","rabbit","bird","fish","other","getGenderName","getAge","birth","Date","now","age","getFullYear","getMonth","getDate","formatDate","date","d","String","padStart","triggerUpload","$refs","avatarInput","click","handleAvatarUpload","event","file","target","files","startsWith","size","formData","FormData","append","url","success","value","editPet","pet","id","$confirm","then","catch","setDefault","viewPetDetail","getPetDetail","submitForm","validate","valid","resetForm","submitVaccine","warning","deleteVaccine","submitHealth","deleteHealth","$nextTick","clearValidate"],"sources":["src/views/personal/MyPets.vue"],"sourcesContent":["<template>\r\n  <div class=\"my-pets-page\">\r\n    <div class=\"page-header\">\r\n      <h2 class=\"page-title\">我的宠物</h2>\r\n      <p class=\"page-desc\">记录宝贝的成长点滴，管理健康档案</p>\r\n      <el-button type=\"primary\" size=\"small\" @click=\"showAddDialog = true\">\r\n        <i class=\"el-icon-plus\"></i> 添加宠物\r\n      </el-button>\r\n    </div>\r\n\r\n    <!-- 宠物列表 -->\r\n    <div class=\"pets-list\" v-loading=\"loading\">\r\n      <div class=\"pet-card\" v-for=\"pet in petList\" :key=\"pet.id\" @click=\"viewPetDetail(pet.id)\">\r\n        <div class=\"pet-avatar\">\r\n          <el-avatar :size=\"80\" :src=\"pet.avatar\" class=\"pet-avatar-img\">\r\n            <i class=\"el-icon-camera\"></i>\r\n          </el-avatar>\r\n          <span class=\"default-badge\" v-if=\"pet.isDefault === 1\">默认</span>\r\n        </div>\r\n        <div class=\"pet-info\">\r\n          <h3 class=\"pet-name\">{{ pet.name }}</h3>\r\n          <div class=\"pet-meta\">\r\n            <span class=\"pet-type\">{{ getTypeName(pet.type) }}</span>\r\n            <span class=\"pet-breed\" v-if=\"pet.breed\">{{ pet.breed }}</span>\r\n          </div>\r\n          <div class=\"pet-stats\">\r\n            <span><i class=\"el-icon-cake\"></i> {{ getAge(pet.birthday) }}</span>\r\n            <span><i class=\"el-icon-weight\"></i> {{ pet.weight || '--' }} kg</span>\r\n          </div>\r\n        </div>\r\n        <div class=\"pet-actions\" @click.stop>\r\n          <el-button type=\"text\" @click=\"editPet(pet)\">\r\n            <i class=\"el-icon-edit\"></i>\r\n          </el-button>\r\n          <el-button type=\"text\" class=\"delete-btn\" @click=\"deletePet(pet)\">\r\n            <i class=\"el-icon-delete\"></i>\r\n          </el-button>\r\n          <el-button v-if=\"pet.isDefault !== 1\" type=\"text\" @click=\"setDefault(pet)\">\r\n            设为默认\r\n          </el-button>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"empty-state\" v-if=\"!loading && petList.length === 0\">\r\n        <i class=\"el-icon-camera\"></i>\r\n        <p>还没有添加宠物</p>\r\n        <el-button type=\"primary\" size=\"small\" @click=\"showAddDialog = true\">添加第一只宠物</el-button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 疫苗提醒卡片 -->\r\n    <div class=\"reminder-card\" v-if=\"upcomingVaccines.length > 0\">\r\n      <div class=\"reminder-header\">\r\n        <i class=\"el-icon-warning\"></i>\r\n        <span>疫苗提醒</span>\r\n      </div>\r\n      <div class=\"reminder-list\">\r\n        <div class=\"reminder-item\" v-for=\"item in upcomingVaccines\" :key=\"item.id\">\r\n          <span class=\"pet-name\">{{ item.petName }}</span>\r\n          <span class=\"vaccine-name\">{{ item.vaccineName }}</span>\r\n          <span class=\"next-date\">下次接种：{{ formatDate(item.nextDate) }}</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 添加/编辑宠物对话框 -->\r\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"showAddDialog\" width=\"550px\" center>\r\n      <el-form :model=\"petForm\" :rules=\"petRules\" ref=\"petForm\" label-width=\"80px\">\r\n        <el-form-item label=\"头像\">\r\n          <div class=\"avatar-upload\" @click=\"triggerUpload\">\r\n            <el-avatar :size=\"80\" :src=\"avatarPreview\" class=\"upload-avatar\">\r\n              <i class=\"el-icon-plus\"></i>\r\n            </el-avatar>\r\n            <input type=\"file\" ref=\"avatarInput\" accept=\"image/*\" style=\"display: none\" @change=\"handleAvatarUpload\">\r\n          </div>\r\n        </el-form-item>\r\n\r\n        <el-form-item label=\"宠物名称\" prop=\"name\">\r\n          <el-input v-model=\"petForm.name\" placeholder=\"给宝贝起个可爱的名字\"></el-input>\r\n        </el-form-item>\r\n\r\n        <el-row :gutter=\"16\">\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"宠物类型\" prop=\"type\">\r\n              <el-select v-model=\"petForm.type\" placeholder=\"请选择\">\r\n                <el-option label=\"狗狗\" value=\"dog\"></el-option>\r\n                <el-option label=\"猫咪\" value=\"cat\"></el-option>\r\n                <el-option label=\"兔子\" value=\"rabbit\"></el-option>\r\n                <el-option label=\"鸟类\" value=\"bird\"></el-option>\r\n                <el-option label=\"鱼类\" value=\"fish\"></el-option>\r\n                <el-option label=\"其他\" value=\"other\"></el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"品种\" prop=\"breed\">\r\n              <el-input v-model=\"petForm.breed\" placeholder=\"如：金毛、布偶猫\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-row :gutter=\"16\">\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"性别\">\r\n              <el-radio-group v-model=\"petForm.gender\">\r\n                <el-radio :label=\"1\">公</el-radio>\r\n                <el-radio :label=\"2\">母</el-radio>\r\n                <el-radio :label=\"0\">未知</el-radio>\r\n              </el-radio-group>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"生日\">\r\n              <el-date-picker v-model=\"petForm.birthday\" type=\"date\" placeholder=\"选择日期\" format=\"yyyy-MM-dd\" value-format=\"yyyy-MM-dd\"></el-date-picker>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-row :gutter=\"16\">\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"体重(kg)\">\r\n              <el-input-number v-model=\"petForm.weight\" :min=\"0\" :max=\"100\" :precision=\"1\"></el-input-number>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"毛色\">\r\n              <el-input v-model=\"petForm.color\" placeholder=\"如：金色、黑白\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-form-item label=\"简介\">\r\n          <el-input v-model=\"petForm.description\" type=\"textarea\" :rows=\"3\" placeholder=\"介绍一下你的宝贝\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n\r\n      <span slot=\"footer\">\r\n        <el-button @click=\"showAddDialog = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitForm\" :loading=\"submitLoading\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n\r\n    <!-- 宠物详情对话框 -->\r\n    <el-dialog :title=\"currentPet.name\" :visible.sync=\"showDetailDialog\" width=\"700px\" center>\r\n      <div class=\"pet-detail\" v-if=\"currentPet\">\r\n        <div class=\"detail-header\">\r\n          <el-avatar :size=\"100\" :src=\"currentPet.avatar\" class=\"detail-avatar\">\r\n            <i class=\"el-icon-camera\"></i>\r\n          </el-avatar>\r\n          <div class=\"detail-info\">\r\n            <h3>{{ currentPet.name }}</h3>\r\n            <p>{{ getTypeName(currentPet.type) }} {{ currentPet.breed ? '· ' + currentPet.breed : '' }}</p>\r\n            <p><i class=\"el-icon-cake\"></i> {{ getAge(currentPet.birthday) }}</p>\r\n            <p><i class=\"el-icon-weight\"></i> {{ currentPet.weight || '--' }} kg</p>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"detail-tabs\">\r\n          <el-tabs v-model=\"activeTab\">\r\n            <el-tab-pane label=\"基本信息\" name=\"basic\">\r\n              <div class=\"basic-info\">\r\n                <div class=\"info-row\"><span>性别：</span><span>{{ getGenderName(currentPet.gender) }}</span></div>\r\n                <div class=\"info-row\"><span>毛色：</span><span>{{ currentPet.color || '--' }}</span></div>\r\n                <div class=\"info-row\"><span>简介：</span><span>{{ currentPet.description || '--' }}</span></div>\r\n              </div>\r\n            </el-tab-pane>\r\n\r\n            <el-tab-pane label=\"疫苗记录\" name=\"vaccine\">\r\n              <div class=\"vaccine-section\">\r\n                <el-button type=\"primary\" size=\"small\" @click=\"showVaccineDialog = true\">添加疫苗记录</el-button>\r\n                <el-table :data=\"currentPet.vaccineRecords\" style=\"margin-top: 15px\" size=\"small\">\r\n                  <el-table-column prop=\"vaccineName\" label=\"疫苗名称\"></el-table-column>\r\n                  <el-table-column prop=\"vaccineDate\" label=\"接种日期\" width=\"120\"></el-table-column>\r\n                  <el-table-column prop=\"nextDate\" label=\"下次接种\" width=\"120\"></el-table-column>\r\n                  <el-table-column prop=\"hospital\" label=\"接种医院\"></el-table-column>\r\n                  <el-table-column label=\"操作\" width=\"80\">\r\n                    <template slot-scope=\"scope\">\r\n                      <el-button type=\"text\" class=\"delete-btn\" @click=\"deleteVaccine(scope.row.id)\">删除</el-button>\r\n                    </template>\r\n                  </el-table-column>\r\n                </el-table>\r\n              </div>\r\n            </el-tab-pane>\r\n\r\n            <el-tab-pane label=\"体检记录\" name=\"health\">\r\n              <div class=\"health-section\">\r\n                <el-button type=\"primary\" size=\"small\" @click=\"showHealthDialog = true\">添加体检记录</el-button>\r\n                <el-table :data=\"currentPet.healthRecords\" style=\"margin-top: 15px\" size=\"small\">\r\n                  <el-table-column prop=\"recordDate\" label=\"体检日期\" width=\"120\"></el-table-column>\r\n                  <el-table-column prop=\"weight\" label=\"体重(kg)\" width=\"100\"></el-table-column>\r\n                  <el-table-column prop=\"healthStatus\" label=\"健康状况\"></el-table-column>\r\n                  <el-table-column prop=\"doctor\" label=\"医生\"></el-table-column>\r\n                  <el-table-column label=\"操作\" width=\"80\">\r\n                    <template slot-scope=\"scope\">\r\n                      <el-button type=\"text\" class=\"delete-btn\" @click=\"deleteHealth(scope.row.id)\">删除</el-button>\r\n                    </template>\r\n                  </el-table-column>\r\n                </el-table>\r\n              </div>\r\n            </el-tab-pane>\r\n          </el-tabs>\r\n        </div>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 添加疫苗记录对话框 -->\r\n    <el-dialog title=\"添加疫苗记录\" :visible.sync=\"showVaccineDialog\" width=\"450px\" center>\r\n      <el-form :model=\"vaccineForm\" label-width=\"100px\">\r\n        <el-form-item label=\"疫苗名称\">\r\n          <el-input v-model=\"vaccineForm.vaccineName\" placeholder=\"如：狂犬疫苗\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"接种日期\">\r\n          <el-date-picker v-model=\"vaccineForm.vaccineDate\" type=\"date\" format=\"yyyy-MM-dd\" value-format=\"yyyy-MM-dd\"></el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"下次接种\">\r\n          <el-date-picker v-model=\"vaccineForm.nextDate\" type=\"date\" format=\"yyyy-MM-dd\" value-format=\"yyyy-MM-dd\"></el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"接种医院\">\r\n          <el-input v-model=\"vaccineForm.hospital\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"医生\">\r\n          <el-input v-model=\"vaccineForm.doctor\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"备注\">\r\n          <el-input v-model=\"vaccineForm.remark\" type=\"textarea\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <span slot=\"footer\">\r\n        <el-button @click=\"showVaccineDialog = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitVaccine\" :loading=\"vaccineLoading\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n\r\n    <!-- 添加体检记录对话框 -->\r\n    <el-dialog title=\"添加体检记录\" :visible.sync=\"showHealthDialog\" width=\"450px\" center>\r\n      <el-form :model=\"healthForm\" label-width=\"100px\">\r\n        <el-form-item label=\"体检日期\">\r\n          <el-date-picker v-model=\"healthForm.recordDate\" type=\"date\" format=\"yyyy-MM-dd\" value-format=\"yyyy-MM-dd\"></el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"身高(cm)\">\r\n          <el-input-number v-model=\"healthForm.height\" :min=\"0\" :precision=\"1\"></el-input-number>\r\n        </el-form-item>\r\n        <el-form-item label=\"体重(kg)\">\r\n          <el-input-number v-model=\"healthForm.weight\" :min=\"0\" :precision=\"1\"></el-input-number>\r\n        </el-form-item>\r\n        <el-form-item label=\"体温(℃)\">\r\n          <el-input-number v-model=\"healthForm.temperature\" :min=\"35\" :max=\"42\" :precision=\"1\"></el-input-number>\r\n        </el-form-item>\r\n        <el-form-item label=\"健康状况\">\r\n          <el-input v-model=\"healthForm.healthStatus\" placeholder=\"如：良好\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"诊断结果\">\r\n          <el-input v-model=\"healthForm.diagnosis\" type=\"textarea\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"医生\">\r\n          <el-input v-model=\"healthForm.doctor\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <span slot=\"footer\">\r\n        <el-button @click=\"showHealthDialog = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitHealth\" :loading=\"healthLoading\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { getPetList, addPet, updatePet, deletePet, setDefaultPet, getUpcomingVaccines, addVaccineRecord, deleteVaccineRecord, addHealthRecord, deleteHealthRecord } from '@/api/pet';\r\nimport { uploadPetAvatar } from '@/api/upload';\r\n\r\nexport default {\r\n  name: 'MyPets',\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      submitLoading: false,\r\n      vaccineLoading: false,\r\n      healthLoading: false,\r\n      petList: [],\r\n      upcomingVaccines: [],\r\n      showAddDialog: false,\r\n      showDetailDialog: false,\r\n      showVaccineDialog: false,\r\n      showHealthDialog: false,\r\n      isEdit: false,\r\n      editId: null,\r\n      avatarPreview: '',\r\n      currentPet: null,\r\n      activeTab: 'basic',\r\n      petForm: {\r\n        name: '',\r\n        type: 'dog',\r\n        breed: '',\r\n        gender: 0,\r\n        birthday: '',\r\n        weight: null,\r\n        color: '',\r\n        avatar: '',\r\n        description: ''\r\n      },\r\n      petRules: {\r\n        name: [{ required: true, message: '请输入宠物名称', trigger: 'blur' }],\r\n        type: [{ required: true, message: '请选择宠物类型', trigger: 'change' }]\r\n      },\r\n      vaccineForm: {\r\n        petId: null,\r\n        vaccineName: '',\r\n        vaccineDate: '',\r\n        nextDate: '',\r\n        hospital: '',\r\n        doctor: '',\r\n        remark: ''\r\n      },\r\n      healthForm: {\r\n        petId: null,\r\n        recordDate: '',\r\n        height: null,\r\n        weight: null,\r\n        temperature: null,\r\n        healthStatus: '',\r\n        diagnosis: '',\r\n        doctor: ''\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    dialogTitle() {\r\n      return this.isEdit ? '编辑宠物' : '添加宠物';\r\n    }\r\n  },\r\n  created() {\r\n    this.loadPets();\r\n    this.loadUpcomingVaccines();\r\n  },\r\n  methods: {\r\n    async loadPets() {\r\n      this.loading = true;\r\n      try {\r\n        const res = await getPetList();\r\n        if (res.code === 200) {\r\n          this.petList = res.data;\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('加载失败');\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    async loadUpcomingVaccines() {\r\n      try {\r\n        const res = await getUpcomingVaccines();\r\n        if (res.code === 200) {\r\n          this.upcomingVaccines = res.data;\r\n        }\r\n      } catch (error) {\r\n        console.error('加载疫苗提醒失败', error);\r\n      }\r\n    },\r\n    getTypeName(type) {\r\n      const map = { dog: '狗狗', cat: '猫咪', rabbit: '兔子', bird: '鸟类', fish: '鱼类', other: '其他' };\r\n      return map[type] || '宠物';\r\n    },\r\n    getGenderName(gender) {\r\n      const map = { 0: '未知', 1: '公', 2: '母' };\r\n      return map[gender] || '未知';\r\n    },\r\n    getAge(birthday) {\r\n      if (!birthday) return '年龄未知';\r\n      const birth = new Date(birthday);\r\n      const now = new Date();\r\n      let age = now.getFullYear() - birth.getFullYear();\r\n      if (now.getMonth() < birth.getMonth() || (now.getMonth() === birth.getMonth() && now.getDate() < birth.getDate())) {\r\n        age--;\r\n      }\r\n      return age + '岁';\r\n    },\r\n    formatDate(date) {\r\n      if (!date) return '';\r\n      const d = new Date(date);\r\n      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;\r\n    },\r\n    triggerUpload() {\r\n      this.$refs.avatarInput.click();\r\n    },\r\n    async handleAvatarUpload(event) {\r\n      const file = event.target.files[0];\r\n      if (!file) return;\r\n      if (!file.type.startsWith('image/')) {\r\n        this.$message.error('只支持图片格式');\r\n        return;\r\n      }\r\n      if (file.size > 2 * 1024 * 1024) {\r\n        this.$message.error('图片不能超过2MB');\r\n        return;\r\n      }\r\n      const formData = new FormData();\r\n      formData.append('file', file);\r\n      try {\r\n        const res = await uploadPetAvatar(formData);\r\n        if (res.code === 200) {\r\n          this.avatarPreview = res.data.url;\r\n          this.petForm.avatar = res.data.url;\r\n          this.$message.success('上传成功');\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('上传失败');\r\n      }\r\n      event.target.value = '';\r\n    },\r\n    editPet(pet) {\r\n      this.isEdit = true;\r\n      this.editId = pet.id;\r\n      this.petForm = {\r\n        name: pet.name,\r\n        type: pet.type,\r\n        breed: pet.breed || '',\r\n        gender: pet.gender || 0,\r\n        birthday: pet.birthday || '',\r\n        weight: pet.weight,\r\n        color: pet.color || '',\r\n        avatar: pet.avatar || '',\r\n        description: pet.description || ''\r\n      };\r\n      this.avatarPreview = pet.avatar || '';\r\n      this.showAddDialog = true;\r\n    },\r\n    async deletePet(pet) {\r\n      this.$confirm(`确定要删除宠物 \"${pet.name}\" 吗？`, '提示', { type: 'warning' }).then(async () => {\r\n        try {\r\n          const res = await deletePet(pet.id);\r\n          if (res.code === 200) {\r\n            this.$message.success('删除成功');\r\n            this.loadPets();\r\n          }\r\n        } catch (error) {\r\n          this.$message.error('删除失败');\r\n        }\r\n      }).catch(() => {});\r\n    },\r\n    async setDefault(pet) {\r\n      try {\r\n        const res = await setDefaultPet(pet.id);\r\n        if (res.code === 200) {\r\n          this.$message.success('设置成功');\r\n          this.loadPets();\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('设置失败');\r\n      }\r\n    },\r\n    async viewPetDetail(id) {\r\n      const res = await getPetDetail(id);\r\n      if (res.code === 200) {\r\n        this.currentPet = res.data;\r\n        this.vaccineForm.petId = id;\r\n        this.healthForm.petId = id;\r\n        this.showDetailDialog = true;\r\n      }\r\n    },\r\n