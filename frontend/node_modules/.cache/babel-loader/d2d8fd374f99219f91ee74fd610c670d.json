"container\">\r\n        <!-- 分类导航 -->\r\n        <div class=\"category-nav\">\r\n          <div class=\"category-list\">\r\n            <span\r\n                v-for=\"cat in categories\"\r\n                :key=\"cat.id\"\r\n                :class=\"['category-item', { active: currentCategory === cat.id }]\"\r\n                @click=\"handleCategoryChange(cat.id)\"\r\n            >\r\n              {{ cat.name }}\r\n            </span>\r\n          </div>\r\n          <div class=\"search-box\">\r\n            <el-input\r\n                v-model=\"keyword\"\r\n                placeholder=\"搜索商品\"\r\n                size=\"medium\"\r\n                @keyup.enter=\"handleSearch\"\r\n                clearable\r\n            >\r\n              <i slot=\"prefix\" class=\"el-icon-search\"></i>\r\n              <el-button slot=\"append\" @click=\"handleSearch\">搜索</el-button>\r\n            </el-input>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 排序栏 -->\r\n        <div class=\"sort-bar\">\r\n          <span\r\n              :class=\"['sort-item', { active: sortType === 'default' }]\"\r\n              @click=\"handleSort('default')\"\r\n          >默认</span>\r\n          <span\r\n              :class=\"['sort-item', { active: sortType === 'price_asc' }]\"\r\n              @click=\"handleSort('price_asc')\"\r\n          >价格升序 <i class=\"el-icon-arrow-up\"></i></span>\r\n          <span\r\n              :class=\"['sort-item', { active: sortType === 'price_desc' }]\"\r\n              @click=\"handleSort('price_desc')\"\r\n          >价格降序 <i class=\"el-icon-arrow-down\"></i></span>\r\n          <span\r\n              :class=\"['sort-item', { active: sortType === 'sales' }]\"\r\n              @click=\"handleSort('sales')\"\r\n          >销量</span>\r\n        </div>\r\n\r\n        <!-- 商品网格 -->\r\n        <div class=\"products-grid\" v-loading=\"loading\">\r\n          <div\r\n              v-for=\"product in productList\"\r\n              :key=\"product.id\"\r\n              class=\"product-card\"\r\n              @click=\"goToDetail(product.id)\"\r\n          >\r\n            <div class=\"product-image\">\r\n              <img :src=\"product.image\" :alt=\"product.name\">\r\n              <span class=\"product-tag\" v-if=\"product.isHot === 1\">热卖</span>\r\n              <span class=\"product-tag new-tag\" v-else-if=\"product.isNew === 1\">新品</span>\r\n            </div>\r\n            <div class=\"product-info\">\r\n              <h4>{{ product.name }}</h4>\r\n              <p class=\"product-desc\">{{ product.description }}</p>\r\n              <div class=\"product-price\">\r\n                <span class=\"current-price\">¥{{ product.price }}</span>\r\n                <span class=\"original-price\" v-if=\"product.originalPrice\">¥{{ product.originalPrice }}</span>\r\n              </div>\r\n              <div class=\"product-footer\">\r\n                <span class=\"sales\">已售 {{ product.sales }}</span>\r\n                <el-button size=\"small\" type=\"primary\" plain @click.stop=\"addToCart(product)\">加入购物车</el-button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 空状态 -->\r\n        <div class=\"empty-state\" v-if=\"!loading && productList.length === 0\">\r\n          <i class=\"el-icon-shopping-cart-2\"></i>\r\n          <p>暂无商品</p>\r\n        </div>\r\n\r\n        <!-- 分页 -->\r\n        <div class=\"pagination\" v-if=\"total > pageSize\">\r\n          <el-pagination\r\n              @current-change=\"handlePageChange\"\r\n              :current-page=\"page\"\r\n              :page-size=\"pageSize\"\r\n              layout=\"prev, pager, next\"\r\n              :total=\"total\"\r\n              background\r\n          >\r\n          </el-pagination>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <Footer />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Navbar from '@/components/Navbar.vue';\r\nimport Footer from '@/components/Footer.vue';\r\nimport { getProductList } from '@/api/product';\r\nimport { addToCart } from '@/api/cart';\r\n\r\nexport default {\r\n  name: 'Shop',\r\n  components: { Navbar, Footer },\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      productList: [],\r\n      categories: [\r\n        { id: null, name: '全部' },\r\n        { id: 1, name: '狗粮' },\r\n        { id: 2, name: '猫粮' },\r\n        { id: 3, name: '玩具' },\r\n        { id: 4, name: '窝垫' },\r\n        { id: 5, name: '洗护' }\r\n      ],\r\n      currentCategory: null,\r\n      keyword: '',\r\n      sortType: 'default',\r\n      page: 1,\r\n      pageSize: 12,\r\n      total: 0\r\n    };\r\n  },\r\n  created() {\r\n    this.loadProducts();\r\n  },\r\n  methods: {\r\n    async loadProducts() {\r\n      this.loading = true;\r\n      try {\r\n        const params = {\r\n          page: this.page,\r\n          pageSize: this.pageSize,\r\n          keyword: this.keyword || undefined,\r\n          categoryId: this.currentCategory || undefined\r\n        };\r\n\r\n        if (this.sortType === 'price_asc') params.sort = 'price_asc';\r\n        if (this.sortType === 'price_desc') params.sort = 'price_desc';\r\n        if (this.sortType === 'sales') params.sort = 'sales';\r\n\r\n        const res = await getProductList(params);\r\n        if (res.code === 200) {\r\n          this.productList = res.data.list;\r\n          this.total = res.data.total;\r\n        }\r\n      } catch (error) {\r\n        this.$message.error('加载失败');\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    handleCategoryChange(categoryId) {\r\n      this.currentCategory = categoryId;\r\n      this.page = 1;\r\n      this.loadProducts();\r\n    },\r\n    handleSearch() {\r\n      this.page = 1;\r\n      this.loadProducts();\r\n    },\r\n    handleSort(type) {\r\n      this.sortType = type;\r\n      this.page = 1;\r\n      this.loadProducts();\r\n    },\r\n    handlePageChange(page) {\r\n      this.page = page;\r\n      th