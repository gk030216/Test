{"remainingRequest":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\babel-loader\\lib\\index.js!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\admin\\CommentManage.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\src\\views\\admin\\CommentManage.vue","mtime":1774494973115},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\babel.config.js","mtime":1773246789976},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773246966744},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\babel-loader\\lib\\index.js","mtime":1773246968572},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773246966744},{"path":"C:\\Users\\87456\\Desktop\\pet-service-system\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1773246969499}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["getCommentList","updateCommentStatus","deleteComment","batchDeleteComments","replyComment","name","data","loading","replyLoading","commentList","total","page","pageSize","selectedRows","searchForm","keyword","rating","status","replyStatus","replyVisible","replyContent","currentComment","created","loadList","methods","params","undefined","res","code","list","map","item","statusLoading","error","console","$message","handleSearch","handleReset","handlePageChange","handleSizeChange","size","handleSelectionChange","rows","formatDate","date","d","Date","getFullYear","String","getMonth","padStart","getDate","getHours","getMinutes","handleStatusChange","row","val","newStatus","action","$confirm","confirmButtonText","cancelButtonText","type","then","id","success","message","catch","handleDelete","handleBatchDelete","length","ids","join","openReplyDialog","reply","submitReply","trim","warning"],"sources":["src/views/admin/CommentManage.vue"],"sourcesContent":["<template>\r\n  <div class=\"comment-manage\">\r\n    <!-- 顶部操作栏 -->\r\n    <div class=\"action-bar\">\r\n      <div class=\"action-left\">\r\n        <el-button\r\n            v-if=\"selectedRows.length > 0\"\r\n            type=\"danger\"\r\n            plain\r\n            @click=\"handleBatchDelete\"\r\n            class=\"batch-btn\"\r\n        >\r\n          <i class=\"el-icon-delete\"></i> 批量删除 ({{ selectedRows.length }})\r\n        </el-button>\r\n      </div>\r\n      <div class=\"action-right\">\r\n        <div class=\"search-wrapper\">\r\n          <i class=\"el-icon-search search-icon\"></i>\r\n          <el-input\r\n              v-model=\"searchForm.keyword\"\r\n              placeholder=\"搜索商品/用户/内容\"\r\n              clearable\r\n              size=\"medium\"\r\n              @keyup.enter=\"handleSearch\"\r\n              class=\"search-input\"\r\n          >\r\n          </el-input>\r\n        </div>\r\n        <el-select\r\n            v-model=\"searchForm.rating\"\r\n            placeholder=\"评分\"\r\n            clearable\r\n            size=\"medium\"\r\n            class=\"status-select\"\r\n            @change=\"handleSearch\"\r\n        >\r\n          <el-option label=\"5星\" :value=\"5\"></el-option>\r\n          <el-option label=\"4星\" :value=\"4\"></el-option>\r\n          <el-option label=\"3星\" :value=\"3\"></el-option>\r\n          <el-option label=\"2星\" :value=\"2\"></el-option>\r\n          <el-option label=\"1星\" :value=\"1\"></el-option>\r\n        </el-select>\r\n        <el-select\r\n            v-model=\"searchForm.status\"\r\n            placeholder=\"状态\"\r\n            clearable\r\n            size=\"medium\"\r\n            class=\"status-select\"\r\n            @change=\"handleSearch\"\r\n        >\r\n          <el-option label=\"全部\" :value=\"''\"></el-option>\r\n          <el-option label=\"显示\" :value=\"1\"></el-option>\r\n          <el-option label=\"隐藏\" :value=\"0\"></el-option>\r\n        </el-select>\r\n        <el-select\r\n            v-model=\"searchForm.replyStatus\"\r\n            placeholder=\"回复状态\"\r\n            clearable\r\n            size=\"medium\"\r\n            class=\"status-select\"\r\n            @change=\"handleSearch\"\r\n        >\r\n          <el-option label=\"全部\" :value=\"''\"></el-option>\r\n          <el-option label=\"未回复\" :value=\"0\"></el-option>\r\n          <el-option label=\"已回复\" :value=\"1\"></el-option>\r\n        </el-select>\r\n        <el-button type=\"primary\" size=\"medium\" @click=\"handleSearch\" class=\"search-btn\">\r\n          搜索\r\n        </el-button>\r\n        <el-button size=\"medium\" @click=\"handleReset\" class=\"reset-btn\">\r\n          重置\r\n        </el-button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 评价表格 -->\r\n    <el-table\r\n        v-loading=\"loading\"\r\n        :data=\"commentList\"\r\n        stripe\r\n        style=\"width: 100%\"\r\n        class=\"comment-table\"\r\n        @selection-change=\"handleSelectionChange\"\r\n    >\r\n      <el-table-column type=\"selection\" width=\"45\" align=\"center\"></el-table-column>\r\n      <el-table-column prop=\"id\" label=\"ID\" width=\"70\" align=\"center\"></el-table-column>\r\n\r\n      <!-- 商品信息列 -->\r\n      <el-table-column label=\"商品信息\" min-width=\"280\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"product-info-cell\">\r\n            <el-image\r\n                :src=\"scope.row.productImage\"\r\n                class=\"product-img\"\r\n                fit=\"cover\"\r\n                :preview-src-list=\"[scope.row.productImage]\"\r\n            >\r\n              <div slot=\"error\" class=\"image-slot\">\r\n                <i class=\"el-icon-picture-outline\"></i>\r\n                <span>暂无图片</span>\r\n              </div>\r\n            </el-image>\r\n            <div class=\"product-detail\">\r\n              <div class=\"product-name\">{{ scope.row.productName || '商品已删除' }}</div>\r\n              <div class=\"product-price\">¥{{ scope.row.productPrice || '0.00' }}</div>\r\n              <div class=\"product-id\">商品ID: {{ scope.row.productId }}</div>\r\n            </div>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 用户列 -->\r\n      <el-table-column label=\"用户\" width=\"160\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"user-info\">\r\n            <el-avatar\r\n                :size=\"40\"\r\n                :src=\"scope.row.userAvatar\"\r\n                class=\"user-avatar\"\r\n            >\r\n              {{ scope.row.userName ? scope.row.userName.charAt(0).toUpperCase() : 'U' }}\r\n            </el-avatar>\r\n            <div class=\"user-detail\">\r\n              <span class=\"user-name\">{{ scope.row.userName }}</span>\r\n              <span class=\"user-id\">ID: {{ scope.row.userId }}</span>\r\n            </div>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 评分列 -->\r\n      <el-table-column label=\"评分\" width=\"120\" align=\"center\">\r\n        <template slot-scope=\"scope\">\r\n          <el-rate v-model=\"scope.row.rating\" disabled show-score text-color=\"#ff9900\"></el-rate>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 评价内容列 -->\r\n      <el-table-column label=\"评价内容\" min-width=\"280\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"comment-content\">{{ scope.row.content }}</div>\r\n          <div class=\"comment-images\" v-if=\"scope.row.images\">\r\n            <el-image\r\n                v-for=\"(img, idx) in scope.row.images.split(',')\"\r\n                :key=\"idx\"\r\n                :src=\"img\"\r\n                :preview-src-list=\"scope.row.images.split(',')\"\r\n                fit=\"cover\"\r\n                class=\"comment-img\"\r\n            ></el-image>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 状态列 - 保留切换开关 -->\r\n      <el-table-column label=\"状态\" width=\"100\" align=\"center\">\r\n        <template slot-scope=\"scope\">\r\n          <el-switch\r\n              :value=\"scope.row.status === 1\"\r\n              active-color=\"#67c23a\"\r\n              inactive-color=\"#f56c6c\"\r\n              @change=\"(val) => handleStatusChange(scope.row, val)\"\r\n              :loading=\"scope.row.statusLoading\"\r\n          >\r\n          </el-switch>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 评价时间 -->\r\n      <el-table-column prop=\"createTime\" label=\"评价时间\" width=\"170\">\r\n        <template slot-scope=\"scope\">\r\n          {{ formatDate(scope.row.createTime) }}\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 商家回复列 -->\r\n      <el-table-column label=\"商家回复\" width=\"200\">\r\n        <template slot-scope=\"scope\">\r\n          <div v-if=\"scope.row.reply\" class=\"reply-text\">\r\n            <div class=\"reply-content\">{{ scope.row.reply }}</div>\r\n            <div class=\"reply-time\">{{ formatDate(scope.row.replyTime) }}</div>\r\n          </div>\r\n          <el-button v-else size=\"small\" type=\"primary\" plain @click=\"openReplyDialog(scope.row)\">\r\n            <i class=\"el-icon-chat-dot-round\"></i> 回复\r\n          </el-button>\r\n        </template>\r\n      </el-table-column>\r\n\r\n      <!-- 操作列 -->\r\n      <el-table-column label=\"操作\" width=\"140\" align=\"center\" fixed=\"right\">\r\n        <template slot-scope=\"scope\">\r\n          <div class=\"action-buttons\">\r\n            <el-button\r\n                size=\"small\"\r\n                type=\"primary\"\r\n                plain\r\n                circle\r\n                @click=\"openReplyDialog(scope.row)\"\r\n                class=\"action-icon-btn\"\r\n                title=\"回复\"\r\n            >\r\n              <i class=\"el-icon-chat-dot-round\"></i>\r\n            </el-button>\r\n            <el-button\r\n                size=\"small\"\r\n                type=\"danger\"\r\n                plain\r\n                circle\r\n                @click=\"handleDelete(scope.row)\"\r\n                class=\"action-icon-btn\"\r\n                title=\"删除\"\r\n            >\r\n              <i class=\"el-icon-delete\"></i>\r\n            </el-button>\r\n          </div>\r\n        </template>\r\n      </el-table-column>\r\n    </el-table>\r\n\r\n    <!-- 分页 -->\r\n    <div class=\"pagination-wrapper\">\r\n      <el-pagination\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handlePageChange\"\r\n          :current-page=\"page\"\r\n          :page-sizes=\"[10, 20, 50]\"\r\n          :page-size=\"pageSize\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          :total=\"total\"\r\n          background\r\n      ></el-pagination>\r\n    </div>\r\n\r\n    <!-- 回复对话框 -->\r\n    <el-dialog title=\"回复评价\" :visible.sync=\"replyVisible\" width=\"550px\" center class=\"reply-dialog\">\r\n      <div class=\"dialog-content\">\r\n        <!-- 商品信息 -->\r\n        <div class=\"product-info-section\">\r\n          <div class=\"section-title\">\r\n            <i class=\"el-icon-goods\"></i>\r\n            <span>商品信息</span>\r\n          </div>\r\n          <div class=\"product-info-card\" v-if=\"currentComment\">\r\n            <el-image\r\n                :src=\"currentComment.productImage\"\r\n                class=\"product-img\"\r\n                fit=\"cover\"\r\n            >\r\n              <div slot=\"error\" class=\"image-slot\">\r\n                <i class=\"el-icon-picture-outline\"></i>\r\n              </div>\r\n            </el-image>\r\n            <div class=\"product-detail\">\r\n              <div class=\"product-name\">{{ currentComment.productName || '商品已删除' }}</div>\r\n              <div class=\"product-price\">¥{{ currentComment.productPrice || '0.00' }}</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 用户评价 -->\r\n        <div class=\"user-comment-section\">\r\n          <div class=\"section-title\">\r\n            <i class=\"el-icon-chat-dot-round\"></i>\r\n            <span>用户评价</span>\r\n          </div>\r\n          <div class=\"original-comment\" v-if=\"currentComment\">\r\n            <div class=\"comment-header\">\r\n              <div class=\"user-info\">\r\n                <el-avatar\r\n                    :size=\"36\"\r\n                    :src=\"currentComment.userAvatar\"\r\n                    class=\"user-avatar\"\r\n                >\r\n                  {{ currentComment.userName ? currentComment.userName.charAt(0).toUpperCase() : 'U' }}\r\n                </el-avatar>\r\n                <div class=\"user-detail\">\r\n                  <span class=\"user-name\">{{ currentComment.userName }}</span>\r\n                  <el-rate v-model=\"currentComment.rating\" disabled text-color=\"#ff9900\"></el-rate>\r\n                </div>\r\n              </div>\r\n              <div class=\"comment-time\">{{ formatDate(currentComment.createTime) }}</div>\r\n            </div>\r\n            <div class=\"comment-content\">{{ currentComment.content }}</div>\r\n            <div class=\"comment-images\" v-if=\"currentComment.images\">\r\n              <el-image\r\n                  v-for=\"(img, idx) in currentComment.images.split(',')\"\r\n                  :key=\"idx\"\r\n                  :src=\"img\"\r\n                  fit=\"cover\"\r\n                  class=\"comment-img\"\r\n              ></el-image>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 回复输入 -->\r\n        <div class=\"reply-input-section\">\r\n          <div class=\"section-title\">\r\n            <i class=\"el-icon-edit\"></i>\r\n            <span>商家回复</span>\r\n          </div>\r\n          <el-input\r\n              type=\"textarea\"\r\n              v-model=\"replyContent\"\r\n              rows=\"4\"\r\n              placeholder=\"请输入回复内容...\"\r\n              maxlength=\"500\"\r\n              show-word-limit\r\n          ></el-input>\r\n        </div>\r\n      </div>\r\n\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"replyVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitReply\" :loading=\"replyLoading\">\r\n          <i class=\"el-icon-check\"></i> 确定回复\r\n        </el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport {\r\n  getCommentList,\r\n  updateCommentStatus,\r\n  deleteComment,\r\n  batchDeleteComments,\r\n  replyComment\r\n} from '@/api/comment';\r\n\r\nexport default {\r\n  name: 'CommentManage',\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      replyLoading: false,\r\n      commentList: [],\r\n      total: 0,\r\n      page: 1,\r\n      pageSize: 10,\r\n      selectedRows: [],\r\n      searchForm: {\r\n        keyword: '',\r\n        rating: '',\r\n        status: '',\r\n        replyStatus: ''\r\n      },\r\n      replyVisible: false,\r\n      replyContent: '',\r\n      currentComment: null\r\n    };\r\n  },\r\n  created() {\r\n    this.loadList();\r\n  },\r\n  methods: {\r\n    async loadList() {\r\n      this.loading = true;\r\n      try {\r\n        const params = {\r\n          page: this.page,\r\n          pageSize: this.pageSize,\r\n          keyword: this.searchForm.keyword || undefined,\r\n          rating: this.searchForm.rating || undefined,\r\n          status: this.searchForm.status !== '' ? this.searchForm.status : undefined,\r\n          replyStatus: this.searchForm.replyStatus !== '' ? this.searchForm.replyStatus : undefined\r\n        };\r\n        const res = await getCommentList(params);\r\n        if (res.code === 200) {\r\n          // 为每条数据添加 loading 状态\r\n          this.commentList = res.data.list.map(item => ({\r\n            ...item,\r\n            statusLoading: false\r\n          }));\r\n          this.total = res.data.total;\r\n        }\r\n      } catch (error) {\r\n        console.error('加载评价列表失败', error);\r\n        this.$message.error('加载失败');\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n\r\n    handleSearch() {\r\n      this.page = 1;\r\n      this.loadList();\r\n    },\r\n\r\n    handleReset() {\r\n      this.searchForm = {\r\n        keyword: '',\r\n        rating: '',\r\n        status: '',\r\n        replyStatus: ''\r\n      };\r\n      this.page = 1;\r\n      this.loadList();\r\n    },\r\n\r\n    handlePageChange(page) {\r\n      this.page = page;\r\n      this.loadList();\r\n    },\r\n\r\n    handleSizeChange(size) {\r\n      this.pageSize = size;\r\n      this.page = 1;\r\n      this.loadList();\r\n    },\r\n\r\n    handleSelectionChange(rows) {\r\n      this.selectedRows = rows;\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return '';\r\n      const d = new Date(date);\r\n      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;\r\n    },\r\n\r\n    async handleStatusChange(row, val) {\r\n      const newStatus = val ? 1 : 0;\r\n      const action = newStatus === 1 ? '显示' : '隐藏';\r\n\r\n      this.$confirm(`确定要${action}该评价吗？`, '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: newStatus === 1 ? 'info' : 'warning'\r\n      }).then(async () => {\r\n        row.statusLoading = true;\r\n        try {\r\n          const res = await updateCommentStatus(row.id, newStatus);\r\n          if (res.code === 200) {\r\n            row.status = newStatus;\r\n            this.$message.success(`${action}成功`);\r\n            // 如果当前筛选状态与修改后的状态不符，刷新列表\r\n            if (this.searchForm.status !== '' && this.searchForm.status !== newStatus) {\r\n              this.loadList();\r\n            }\r\n          } else {\r\n            this.$message.error(res.message);\r\n          }\r\n        } catch (error) {\r\n          this.$message.error('操作失败');\r\n        } finally {\r\n          row.statusLoading = false;\r\n        }\r\n      }).catch(() => {});\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      this.$confirm(`确定要删除该评价吗？删除后无法恢复！`, '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(async () => {\r\n        try {\r\n          const res = await deleteComment(row.id);\r\n          if (res.code === 200) {\r\n            this.$message.success('删除成功');\r\n            this.loadList();\r\n          } else {\r\n            this.$message.error(res.message);\r\n          }\r\n        } catch (error) {\r\n          this.$message.error('删除失败');\r\n        }\r\n      }).catch(() => {});\r\n    },\r\n\r\n    async handleBatchDelete() {\r\n      if (this.selectedRows.length === 0) return;\r\n      const ids = this.selectedRows.map(row => row.id).join(',');\r\n      this.$confirm(`确定要删除选中的 ${this.selectedRows.length} 条评价吗？`, '警告', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(async () => {\r\n        try {\r\n          const res = await batchDeleteComments(ids);\r\n          if (res.code === 200) {\r\n            this.$message.success(res.message);\r\n            this.selectedRows = [];\r\n            this.loadList();\r\n          } else {\r\n            this.$message.error(res.message);\r\n          }\r\n        } catch (error) {\r\n          this.$message.error('批量删除失败');\r\n        }\r\n      }).catch(() => {});\r\n    },\r\n\r\n    openReplyDialog(row) {\r\n      this.currentComment = row;\r\n      this.replyContent = row.reply || '';\r\n      this.replyVisible = true;\r\n    },\r\n\r\n    async submitReply() {\r\n      if (!this.replyContent.trim()) {\r\n        this.$message.warning('请输入回复内容');\r\n        return;\r\n      }\r\n      this.replyLoading = true;\r\n      try {\r\n        const res = await replyComment(this.currentComment.id, this.replyContent);\r\n        if (res.code === 200) {\r\n          this.$message.success('回复成功');\r\n          this.replyVisible = false;\r\n          this.loadList();\r\n        } else {\r\n          this.$message.error(res.message);\r\n        }\r\n      } catch (error) {\r\n        console.error('回复失败', error);\r\n        this.$message.error('回复失败');\r\n      } finally {\r\n        this.replyLoading = false;\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.comment-manage {\r\n  padding: 20px;\r\n  background: #f5f7fa;\r\n  min-height: 100%;\r\n}\r\n\r\n.action-bar {\r\n  background: #fff;\r\n  border-radius: 16px;\r\n  padding: 16px 24px;\r\n  margin-bottom: 20px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  flex-wrap: wrap;\r\n  gap: 16px;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);\r\n}\r\n\r\n.action-left {\r\n  display: flex;\r\n  gap: 12px;\r\n  flex-wrap: wrap;\r\n  align-items: center;\r\n}\r\n\r\n.action-right {\r\n  display: flex;\r\n  gap: 12px;\r\n  flex-wrap: wrap;\r\n  align-items: center;\r\n}\r\n\r\n.batch-btn {\r\n  border-radius: 8px;\r\n  font-weight: 500;\r\n  transition: all 0.2s;\r\n}\r\n\r\n.search-wrapper {\r\n  position: relative;\r\n  display: inline-block;\r\n}\r\n\r\n.search-icon {\r\n  position: absolute;\r\n  left: 12px;\r\n  top: 50%;\r\n  transform: translateY(-50%);\r\n  color: #909399;\r\n  font-size: 16px;\r\n  z-index: 1;\r\n}\r\n\r\n.search-input {\r\n  width: 240px;\r\n}\r\n\r\n.search-input ::v-deep .el-input__inner {\r\n  padding-left: 36px;\r\n  border-radius: 8px;\r\n}\r\n\r\n.status-select {\r\n  width: 100px;\r\n}\r\n\r\n.status-select ::v-deep .el-input__inner {\r\n  