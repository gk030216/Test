\r\n// 删除帖子\r\nexport function deletePost(id) {\r\n    return request({\r\n        url: `/community/post/${id}`,\r\n        method: 'delete'\r\n    });\r\n}\r\n\r\n// 获取用户帖子列表\r\nexport function getUserPosts(params) {\r\n    return request({\r\n        url: '/community/user/posts',\r\n        method: 'get',\r\n        params\r\n    });\r\n}\r\n\r\n// 获取收藏列表\r\nexport function getFavorites(params) {\r\n    return request({\r\n        url: '/community/favorites',\r\n        method: 'get',\r\n        params\r\n    });\r\n}\r\n\r\n// 点赞/取消点赞\r\nexport function toggleLike(id) {\r\n    return request({\r\n        url: `/community/post/${id}/like`,\r\n        method: 'post'\r\n    });\r\n}\r\n\r\n// 收藏/取消收藏\r\nexport function toggleFavorite(id) {\r\n    return request({\r\n        url: `/community/post/${id}/favorite`,\r\n        method: 'post'\r\n    });\r\n}\r\n\r\n// ========== 评论相关 ==========\r\n\r\n// 获取帖子评论\r\nexport function getComments(postId, params) {\r\n    return request({\r\n        url: `/community/post/${postId}/comments`,\r\n        method: 'get',\r\n        params\r\n    });\r\n}\r\n\r\n// 添加评论\r\nexport function addComment(data) {\r\n    return request({\r\n        url: '/community/comment',\r\n        method: 'post',\r\n        data\r\n    });\r\n}\r\n\r\n// 删除评论\r\nexport function deleteComment(id) {\r\n    return request({\r\n        url: `/community/comment/${id}`,\r\n        method: 'delete'\r\n    });\r\n}\r\n\r\n// ========== 管理员接口 ==========\r\n\r\n// 获取帖子列表（后台）\r\nexport function getAdminPostList(params) {\r\n    return request({\r\n        url: '/admin/community/posts',\r\n        method: 'get',\r\n        params\r\n    });\r\n}\r\n\r\n// 更新帖子状态\r\nexport function updatePostStatus(id, status) {\r\n    return request({\r\n        url: '/admin/community/post/status',\r\n        method: 'put',\r\n        params: { id, status }\r\n    });\r\n}\r\n\r\n// 置顶/取消置顶\r\nexport function updatePostTop(id, isTop) {\r\n    return request({\r\n        url: '/admin/community/post/top',\r\n        method: 'put',\r\n        params: { id, isTop }\r\n    });\r\n}\r\n\r\n// 精华/取消精华\r\nexport function updatePostEssence(id, isEssence) {\r\n    return request({\r\n        url: '/admin/community/post/essence',\r\n        method: 'put',\r\n        params: { id, isEssence }\r\n    });\r\n}\r\n\r\n// 管理员删除帖子\r\nexport function adminDeletePost(id) {\r\n    return request({\r\n        url: `/admin/community/post/${id}`,\r\n        method: 'delete'\r\n    });\r\n}"],"mappings":"AAAA,OAAOA,OAAO,MAAM,iBAAiB;;AAErC;;AAEA;AACA,OAAO,SAASC,WAAWA,CAACC,MAAM,EAAE;EAChC,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,kBAAkB;IACvBC,MAAM,EAAE,KAAK;IACbF;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASG,aAAaA,CAACC,EAAE,EAAE;EAC9B,OAAON,OAAO,CAAC;IACXG,GAAG,EAAE,mBAAmBG,EAAE,EAAE;IAC5BF,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASG,OAAOA,CAACC,IAAI,EAAE;EAC1B,OAAOR,OAAO,CAAC;IACXG,GAAG,EAAE,iBAAiB;IACtBC,MAAM,EAAE,MAAM;IACdI;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASC,UAAUA,CAACD,IAAI,EAAE;EAC7B,OAAOR,OAAO,CAAC;IACXG,GAAG,EAAE,iBAAiB;IACtBC,MAAM,EAAE,KAAK;IACbI;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASE,UAAUA,CAACJ,EAAE,EAAE;EAC3B,OAAON,OAAO,CAAC;IACXG,GAAG,EAAE,mBAAmBG,EAAE,EAAE;IAC5BF,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASO,YAAYA,CAACT,MAAM,EAAE;EACjC,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,uBAAuB;IAC5BC,MAAM,EAAE,KAAK;IACbF;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASU,YAAYA,CAACV,MAAM,EAAE;EACjC,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,sBAAsB;IAC3BC,MAAM,EAAE,KAAK;IACbF;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASW,UAAUA,CAACP,EAAE,EAAE;EAC3B,OAAON,OAAO,CAAC;IACXG,GAAG,EAAE,mBAAmBG,EAAE,OAAO;IACjCF,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASU,cAAcA,CAACR,EAAE,EAAE;EAC/B,OAAON,OAAO,CAAC;IACXG,GAAG,EAAE,mBAAmBG,EAAE,WAAW;IACrCF,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;;AAEA;AACA,OAAO,SAASW,WAAWA,CAACC,MAAM,EAAEd,MAAM,EAAE;EACxC,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,mBAAmBa,MAAM,WAAW;IACzCZ,MAAM,EAAE,KAAK;IACbF;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASe,UAAUA,CAACT,IAAI,EAAE;EAC7B,OAAO