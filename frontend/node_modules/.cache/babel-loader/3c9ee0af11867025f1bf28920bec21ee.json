 '/admin/inventory/add',\r\n        method: 'post',\r\n        data\r\n    });\r\n}\r\n\r\n// 更新库存信息\r\nexport function updateInventory(data) {\r\n    return request({\r\n        url: '/admin/inventory/update',\r\n        method: 'put',\r\n        data\r\n    });\r\n}\r\n\r\n// 入库（增加库存）\r\nexport function addStock(id, quantity) {\r\n    return request({\r\n        url: `/admin/inventory/add-stock/${id}`,\r\n        method: 'put',\r\n        data: { quantity }\r\n    });\r\n}\r\n\r\n// 删除库存\r\nexport function deleteInventory(id) {\r\n    return request({\r\n        url: `/admin/inventory/delete/${id}`,\r\n        method: 'delete'\r\n    });\r\n}\r\n\r\n// 获取库存统计\r\nexport function getInventoryStatistics(type) {\r\n    return request({\r\n        url: '/admin/inventory/statistics',\r\n        method: 'get',\r\n        params: { type }\r\n    });\r\n}\r\n\r\n// 导出疫苗库存列表\r\nexport function exportVaccineList(params) {\r\n    return request({\r\n        url: '/admin/inventory/vaccine/export',\r\n        method: 'get',\r\n        params,\r\n        responseType: 'blob'\r\n    });\r\n}\r\n\r\n// 导出商品库存列表\r\nexport function exportProductInventoryList(params) {\r\n    return request({\r\n        url: '/admin/inventory/product/export',\r\n        method: 'get',\r\n        params,\r\n        responseType: 'blob'\r\n    });\r\n}"],"mappings":"AAAA,OAAOA,OAAO,MAAM,iBAAiB;;AAErC;AACA,OAAO,SAASC,gBAAgBA,CAACC,MAAM,EAAE;EACrC,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,uBAAuB;IAC5BC,MAAM,EAAE,KAAK;IACbF;EACJ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASG,uBAAuBA,CAACH,MAAM,EAAE;EAC5C,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,uBAAuB;IAC5BC,MAAM,EAAE,KAAK;IACbF,MAAM,EAAE;MAAE,GAAGA,MAAM;MAAEI,IAAI,EAAE;IAAU;EACzC,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASC,uBAAuBA,CAACL,MAAM,EAAE;EAC5C,OAAOF,OAAO,CAAC;IACXG,GAAG,EAAE,uBAAuB;IAC5BC,MAAM,EAAE,KAAK;IACbF,MAAM,EAAE;MAAE,GAAGA,MAAM;MAAEI,IAAI,EAAE;IAAU;EACzC,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASE,YAAYA,CAACC,IAAI,EAAE;EAC/B,OAAOT,OAAO,CAAC;IACXG,GAAG,EAAE,sBAAsB;IAC3BC,MAAM,EAAE,