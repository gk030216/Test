: 'put',\r\n        params: { cartId, selected }\r\n    });\r\n}\r\n\r\n// 删除购物车商品\r\nexport function deleteCartItem(cartId) {\r\n    return request({\r\n        url: `/cart/delete/${cartId}`,\r\n        method: 'delete'\r\n    });\r\n}\r\n\r\n// 删除已选中的商品\r\nexport function deleteSelected() {\r\n    return request({\r\n        url: '/cart/delete-selected',\r\n        method: 'delete'\r\n    });\r\n}"],"mappings":"AAAA,OAAOA,OAAO,MAAM,iBAAiB;;AAErC;AACA,OAAO,SAASC,WAAWA,CAAA,EAAG;EAC1B,OAAOD,OAAO,CAAC;IACXE,GAAG,EAAE,YAAY;IACjBC,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASC,cAAcA,CAAA,EAAG;EAC7B,OAAOJ,OAAO,CAAC;IACXE,GAAG,EAAE,eAAe;IACpBC,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASE,SAASA,CAACC,SAAS,EAAEC,QAAQ,GAAG,CAAC,EAAE;EAC/C,OAAOP,OAAO,CAAC;IACXE,GAAG,EAAE,WAAW;IAChBC,MAAM,EAAE,MAAM;IACdK,MAAM,EAAE;MAAEF,SAAS;MAAEC;IAAS;EAClC,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASE,kBAAkBA,CAACC,MAAM,EAAEH,QAAQ,EAAE;EACjD,OAAOP,OAAO,CAAC;IACXE,GAAG,EAAE,gBAAgB;IACrBC,MAAM,EAAE,KAAK;IACbK,MAAM,EAAE;MAAEE,MAAM;MAAEH;IAAS;EAC/B,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASI,kBAAkBA,CAACD,MAAM,EAAEE,QAAQ,EAAE;EACjD,OAAOZ,OAAO,CAAC;IACXE,GAAG,EAAE,gBAAgB;IACrBC,MAAM,EAAE,KAAK;IACbK,MAAM,EAAE;MAAEE,MAAM;MAAEE;IAAS;EAC/B,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASC,cAAcA,CAACH,MAAM,EAAE;EACnC,OAAOV,OAAO,CAAC;IACXE,GAAG,EAAE,gBAAgBQ,MAAM,EAAE;IAC7BP,MAAM,EAAE;EACZ,CAAC,CAAC;AACN;;AAEA;AACA,OAAO,SAASW,cAAcA,CAAA,EAAG;EAC7B,OAAOd,OAAO,CAAC;IACXE,GAAG,EAAE,uBAAuB;IAC5BC,MAAM,EAAE;EACZ,CAAC,CAAC;AACN","ignoreList":[]}]}